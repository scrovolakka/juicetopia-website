---
interface Props {
  prev?: { href: string; chapter: number; title: string };
  next?: { href: string; chapter: number; title: string };
  indexHref: string;
  current: number;
  total: number;
}
const { prev, next, indexHref, current, total } = Astro.props;
const pad = (n: number) => String(n).padStart(2, '0');
---

<nav class="ch-nav" aria-label="Strata-di mokuro">
  <div class="slot prev">
    {
      prev ? (
        <a class="acid-link mono" href={prev.href}>
          <span class="arrow">[←]</span>
          <span class="lbl">ST.{pad(prev.chapter)}</span>
          <span class="t">{prev.title}</span>
        </a>
      ) : (
        <span class="mono meta-dim">[—]</span>
      )
    }
  </div>
  <div class="slot idx">
    <a class="acid-link mono" href={indexHref}>
      <span>{pad(current)}</span><span class="sep">/</span><span>{pad(total)}</span>
      <span class="lbl">MOKURO</span>
    </a>
  </div>
  <div class="slot next">
    {
      next ? (
        <a class="acid-link mono" href={next.href}>
          <span class="t">{next.title}</span>
          <span class="lbl">ST.{pad(next.chapter)}</span>
          <span class="arrow">[→]</span>
        </a>
      ) : (
        <span class="mono meta-dim">[—]</span>
      )
    }
  </div>
</nav>

<style>
  .ch-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-4);
    align-items: center;
    padding-block: var(--space-4);
  }
  .slot.next {
    text-align: right;
  }
  .slot.idx {
    text-align: center;
  }
  .acid-link {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.5em;
    align-items: baseline;
  }
  .next .acid-link {
    justify-content: flex-end;
  }
  .sep {
    color: var(--color-acid-ink);
    padding: 0 0.1em;
  }
  .arrow {
    color: var(--color-acid-ink);
  }
  .t {
    font-family: var(--font-mincho);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
    text-transform: none;
  }
  .lbl {
    color: var(--color-ink);
  }
  @media (max-width: 48rem) {
    .ch-nav {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .slot.next {
      text-align: center;
    }
    .next .acid-link {
      justify-content: center;
    }
  }
</style>
