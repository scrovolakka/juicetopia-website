---
interface Props {
  id: string;
  label: string;
}
const { id, label } = Astro.props;
---

<div class="route-index mono">
  <span class="bracket">[</span>
  <span class="num">{id}</span>
  <span class="sep">/</span>
  <span class="lbl">{label}</span>
  <span class="bracket">]</span>
</div>

<style>
  .route-index {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
    color: var(--color-ink);
  }
  .bracket {
    color: var(--color-ink-muted);
  }
  .num {
    color: var(--color-acid);
    font-weight: 500;
  }
  .sep {
    color: var(--color-ink-muted);
  }
</style>
