---
import logoLight from '~/assets/logo_light.svg?url';
import logoDark from '~/assets/logo_dark.svg?url';

interface Props {
  size?: 'sm' | 'md' | 'lg' | 'hero';
  href?: string;
}
const { size = 'sm', href = import.meta.env.BASE_URL } = Astro.props;
---

<a class:list={['logo', `size-${size}`]} href={href} aria-label="juicetopia — MOKURO">
  <img 
    id="logo-light"
    src={logoLight}
    alt="juicetopia"
    class="logo-image"
  />
  <img 
    id="logo-dark"
    src={logoDark}
    alt="juicetopia"
    class="logo-image"
  />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    line-height: 1;
    position: relative;
  }

  .logo-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .size-sm .logo-image {
    height: 2rem;
  }

  .size-md .logo-image {
    height: 3rem;
  }

  .size-lg .logo-image {
    height: 4rem;
  }

  .size-hero .logo-image {
    height: clamp(4rem, 12vw, 10rem);
  }

  /* Show the appropriate logo based on mode */
  #logo-light {
    display: block;
  }

  #logo-dark {
    display: none;
  }

  :global([data-mode='void']) #logo-light {
    display: none;
  }

  :global([data-mode='void']) #logo-dark {
    display: block;
  }
</style>
