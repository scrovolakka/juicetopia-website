---
interface Props {
  size?: 'sm' | 'md' | 'lg' | 'hero';
  href?: string;
}
const { size = 'sm', href = import.meta.env.BASE_URL } = Astro.props;
---

<a class:list={['logo', `size-${size}`]} href={href} aria-label="juicetopia — INDEX">
  <span class="wordmark">ju<span class="dot">i</span>cetopia</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: baseline;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--color-ink);
    line-height: 1;
  }
  .size-sm .wordmark {
    font-size: 1.125rem;
  }
  .size-md .wordmark {
    font-size: 1.5rem;
  }
  .size-lg .wordmark {
    font-size: 2.25rem;
  }
  .size-hero .wordmark {
    font-size: clamp(3rem, 10vw, 7rem);
    letter-spacing: -0.015em;
  }
  .wordmark {
    position: relative;
  }
  .dot {
    position: relative;
    color: var(--color-ink);
  }
  .dot::after {
    content: '';
    position: absolute;
    top: -0.05em;
    left: 50%;
    width: 0.22em;
    height: 0.22em;
    border-radius: 50%;
    background: var(--color-acid);
    transform: translateX(-50%);
    box-shadow: 0 0 0.25em var(--color-acid-dim);
  }
  /* replace the normal i dot visually */
  .size-sm .dot,
  .size-md .dot,
  .size-lg .dot,
  .size-hero .dot {
    /* keep normal glyph; acid dot sits above it */
  }
</style>
