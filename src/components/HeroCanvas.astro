---
// Hero 3D — client-only Three.js island. Initialized via inline script on idle.
// When [data-node-idx] elements exist in the DOM, they are passed to initHero
// so the 3D scene can project orbiting node positions onto them.
---

<div class="hero-wrap" aria-hidden="true">
  <canvas id="hero-canvas" class="hero-canvas"></canvas>
  <noscript>
    <svg
      class="hero-fallback"
      viewBox="-1.6 -1.6 3.2 3.2"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      stroke="currentColor"
      stroke-width="0.015"
      role="img"
      aria-label="SACRABOLLA — 聖杯"
    >
      <path
        d="M -0.70 1.30 L 0.70 1.30 L 0.72 1.27 L 0.66 1.22 L 0.34 1.14 L 0.22 1.06 L 0.18 0.96 L 0.17 0.88 L 0.22 0.83 L 0.36 0.76 L 0.36 0.62 L 0.22 0.55 L 0.17 0.48 L 0.16 0.40 L 0.22 0.35 L 0.42 0.28 L 0.75 0.12 L 1.00 -0.12 L 1.15 -0.35 L 1.21 -0.52 L 1.23 -0.58 L 1.23 -0.62 L -1.23 -0.62 L -1.23 -0.58 L -1.21 -0.52 L -1.15 -0.35 L -1.00 -0.12 L -0.75 0.12 L -0.42 0.28 L -0.22 0.35 L -0.16 0.40 L -0.17 0.48 L -0.22 0.55 L -0.36 0.62 L -0.36 0.76 L -0.22 0.83 L -0.17 0.88 L -0.18 0.96 L -0.22 1.06 L -0.34 1.14 L -0.66 1.22 L -0.72 1.27 Z"
      />
      <line x1="-1.23" y1="-0.58" x2="1.23" y2="-0.58" />
    </svg>
  </noscript>
</div>

<script>
  import { initHero } from '~/scripts/hero';
  const el = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
  if (el) {
    const nodeLabels = Array.from(
      document.querySelectorAll<HTMLElement>('[data-node-idx]'),
    );
    const start = () => initHero(el, nodeLabels.length > 0 ? nodeLabels : undefined);
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(start, { timeout: 1500 });
    } else {
      setTimeout(start, 200);
    }
  }
</script>

<style>
  .hero-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: min(520px, 88vw);
    max-height: 48vh;
    margin: 0 auto;
  }
  .hero-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
  .hero-fallback {
    width: 100%;
    height: 100%;
    color: var(--color-ink);
  }
</style>
