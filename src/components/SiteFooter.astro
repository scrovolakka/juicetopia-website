---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
const mmxxvi = (() => {
  // simple roman numeral for current year (covers 1900-2099)
  const n = year;
  const numerals: [number, string][] = [
    [1000, 'M'],
    [900, 'CM'],
    [500, 'D'],
    [400, 'CD'],
    [100, 'C'],
    [90, 'XC'],
    [50, 'L'],
    [40, 'XL'],
    [10, 'X'],
    [9, 'IX'],
    [5, 'V'],
    [4, 'IV'],
    [1, 'I'],
  ];
  let x = n;
  let out = '';
  for (const [v, s] of numerals) {
    while (x >= v) {
      out += s;
      x -= v;
    }
  }
  return out;
})();
---

<footer class="site-footer">
  <div class="rule"></div>
  <div class="bar">
    <div class="mono">
      <span>JCT</span><span class="sep">·</span><span>{mmxxvi}</span><span class="sep">·</span><span>A.02</span>
    </div>
    <div class="links mono">
      <a class="foot-a" href={`${base}/cronika/`}>CRONIKA<span class="foot-a-jp">編集後記</span></a>
      <span class="sep">·</span>
      <a class="foot-a" href={`${base}/mondo/`}>MONDO<span class="foot-a-jp">世界注</span></a>
      <span class="sep">·</span>
      <a class="foot-a" href={`${base}/lexicon/`}>LEKSIKO<span class="foot-a-jp">辞書</span></a>
    </div>
    <div class="mono meta-dim motto">
      <span>PANA-DI-BANDA-KA-FORNA-MODA-NE-NEK</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-section);
  }
  .rule {
    border-top: 1px solid var(--color-rule);
  }
  .bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-4) var(--page-pad) var(--space-8);
    flex-wrap: wrap;
  }
  .sep {
    color: var(--color-acid);
    padding: 0 0.4em;
    display: inline-block;
    transition: transform var(--dur-mid) var(--ease-out);
  }
  .bar:hover .sep {
    transform: rotate(90deg);
  }
  .motto {
    font-size: 0.55rem;
    letter-spacing: 0.25em;
  }
  @media (max-width: 48rem) {
    .motto {
      font-size: 0.5rem;
    }
  }
  .links {
    display: inline-flex;
    gap: 0.3em;
    align-items: baseline;
    font-size: var(--fs-meta);
    letter-spacing: 0.12em;
  }
  .foot-a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }
  .foot-a:hover,
  .foot-a:focus-visible {
    border-bottom-color: var(--color-acid);
    color: var(--color-acid);
  }
  .foot-a-jp {
    font-family: var(--font-mincho);
    font-size: 0.75em;
    letter-spacing: 0.2em;
    color: var(--color-ink-muted);
    margin-inline-start: 0.2em;
  }
  @media (max-width: 64rem) {
    .links {
      order: 3;
      flex-basis: 100%;
      justify-content: center;
      padding-top: var(--space-3);
    }
  }
</style>
