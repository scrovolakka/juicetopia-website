---
// Secondary-route background 3D fruits (client-only).
---

<div class="fruit-bg-wrap" aria-hidden="true">
  <canvas id="fruit-bg-canvas" class="fruit-bg-canvas"></canvas>
</div>

<script>
  import { initFruitBackground } from '~/scripts/fruit-background';

  const canvas = document.getElementById('fruit-bg-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const start = () => initFruitBackground(canvas);
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(start, { timeout: 1200 });
    } else {
      setTimeout(start, 180);
    }
  }
</script>

<style>
  .fruit-bg-wrap {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .fruit-bg-canvas {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.44;
  }
  @media (max-width: 48rem) {
    .fruit-bg-canvas {
      opacity: 0.33;
    }
  }
</style>
