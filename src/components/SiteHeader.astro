---
import Logotype from './Logotype.astro';
import { NAV, routeIndex } from '~/lib/nav';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(base, '') || '/';
const current = routeIndex(currentPath);
const buildDate = new Date().toISOString().slice(0, 10).replace(/-/g, '.');
---

<header class="site-header">
  <div class="bar">
    <div class="left">
      <Logotype size="sm" />
    </div>

    <nav class="nav" aria-label="Primary">
      <ul>
        {
          NAV.map((item) => {
            const isCurrent = current?.id === item.id;
            const href = (base + item.href).replace(/\/+/g, '/');
            return (
              <li>
                <a
                  class:list={['nav-link', { 'is-current': isCurrent }]}
                  href={href}
                  aria-current={isCurrent ? 'page' : undefined}
                >
                  <span class="n">{isCurrent ? `_${item.id}_` : `[${item.id}]`}</span>
                  <span class="l">{item.label}</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <button class="burger" id="burger" type="button" aria-label="Menu" aria-expanded="false">
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>

    <div class="right mono">
      <span>{buildDate}</span>
      <span class="sep">·</span>
      <span>OSAKA-SHU</span>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="drawer" id="drawer" aria-hidden="true">
    <nav>
      <ul>
        {
          NAV.map((item) => {
            const isCurrent = current?.id === item.id;
            const href = (base + item.href).replace(/\/+/g, '/');
            return (
              <li>
                <a
                  class:list={['drawer-link', { 'is-current': isCurrent }]}
                  href={href}
                  aria-current={isCurrent ? 'page' : undefined}
                >
                  <span class="n">{isCurrent ? `_${item.id}_` : `[${item.id}]`}</span>
                  <span class="l">{item.label}</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>

  <div class="rule"></div>
</header>

<script>
  const burger = document.getElementById('burger');
  const drawer = document.getElementById('drawer');
  if (burger && drawer) {
    burger.addEventListener('click', () => {
      const open = drawer.getAttribute('aria-hidden') === 'false';
      drawer.setAttribute('aria-hidden', String(open));
      burger.setAttribute('aria-expanded', String(!open));
    });
    // Close on link click
    drawer.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        drawer.setAttribute('aria-hidden', 'true');
        burger.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // Scroll → enhance header blur
  const header = document.querySelector('.site-header') as HTMLElement | null;
  if (header) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        header.classList.toggle('scrolled', window.scrollY > 100);
        ticking = false;
      });
    }, { passive: true });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: color-mix(in srgb, var(--color-bg) 82%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition:
      backdrop-filter var(--dur-mid) var(--ease-out),
      background var(--dur-mid) var(--ease-out);
  }
  .site-header.scrolled {
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    background: color-mix(in srgb, var(--color-bg) 90%, transparent);
  }
  .bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-4) var(--page-pad);
    min-height: 64px;
  }
  .nav ul {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
  .nav-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    text-transform: uppercase;
    color: var(--color-ink);
    padding: 0.25em 0;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav-link .n {
    color: var(--color-acid);
    font-weight: 500;
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    text-shadow:
      -1px 0 0 var(--color-ca-magenta),
      1px 0 0 var(--color-ca-cyan);
  }
  .nav-link .l {
    position: relative;
  }
  .nav-link .l::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--color-acid);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-mid) var(--ease-out);
  }
  .nav-link:hover .l::after,
  .nav-link:focus-visible .l::after {
    transform: scaleX(1);
  }
  .nav-link.is-current .l::after {
    transform: scaleX(1);
  }

  /* Burger button — hidden on desktop */
  .burger {
    display: none;
    justify-self: end;
    width: 2rem;
    height: 2rem;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
  }
  .burger-line {
    display: block;
    width: 1.25rem;
    height: 1.5px;
    background: var(--color-ink);
    transition: transform var(--dur-mid) var(--ease-out), opacity var(--dur-mid) var(--ease-out);
  }
  .burger[aria-expanded='true'] .burger-line:first-child {
    transform: translateY(3.25px) rotate(45deg);
  }
  .burger[aria-expanded='true'] .burger-line:last-child {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  .right {
    justify-self: end;
    display: inline-flex;
    gap: 0.5em;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }
  .right .sep {
    color: var(--color-acid);
  }

  .rule {
    border-bottom: 1px solid var(--color-rule);
  }

  /* Drawer — hidden by default */
  .drawer {
    display: none;
  }
  .drawer[aria-hidden='false'] {
    display: block;
  }
  .drawer nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
  }
  .drawer-link {
    display: flex;
    align-items: baseline;
    gap: 0.5em;
    padding: var(--space-3) var(--page-pad);
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    text-transform: uppercase;
    color: var(--color-ink);
    border-top: 1px solid var(--color-rule);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .drawer-link:hover,
  .drawer-link:focus-visible {
    background: color-mix(in srgb, var(--color-bg) 88%, var(--color-acid) 12%);
  }
  .drawer-link .n {
    color: var(--color-acid);
    font-weight: 500;
  }
  .drawer-link.is-current .l {
    color: var(--color-acid);
  }

  @media (max-width: 48rem) {
    .bar {
      grid-template-columns: auto 1fr auto;
      padding-block: var(--space-3);
    }
    .nav {
      display: none;
    }
    .right {
      display: none;
    }
    .burger {
      display: flex;
    }
  }
</style>
