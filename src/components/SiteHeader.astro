---
import Logotype from './Logotype.astro';
import { NAV, routeIndex } from '~/lib/nav';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(base, '') || '/';
const current = routeIndex(currentPath);
const buildDate = new Date().toISOString().slice(0, 10).replace(/-/g, '.');
---

<header class="site-header">
  <div class="bar">
    <div class="left">
      <Logotype size="sm" />
    </div>

    <nav class="nav" aria-label="Primary">
      <ul>
        {
          NAV.map((item) => {
            const isCurrent = current?.id === item.id;
            const href = (base + item.href).replace(/\/+/g, '/');
            return (
              <li>
                <a
                  class:list={['nav-link', { 'is-current': isCurrent }]}
                  href={href}
                  aria-current={isCurrent ? 'page' : undefined}
                >
                  <span class="n">{isCurrent ? `_${item.id}_` : `[${item.id}]`}</span>
                  <span class="l">{item.label}</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="right mono">
      <span>{buildDate}</span>
      <span class="sep">·</span>
      <span>OSAKA-SHU</span>
    </div>
  </div>
  <div class="rule"></div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: color-mix(in srgb, var(--color-bg) 82%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-4) var(--page-pad);
    min-height: 64px;
  }
  .nav ul {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
  .nav-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    text-transform: uppercase;
    color: var(--color-ink);
    padding: 0.25em 0;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav-link .n {
    color: var(--color-acid);
    font-weight: 500;
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    text-shadow:
      -1px 0 0 var(--color-ca-magenta),
      1px 0 0 var(--color-ca-cyan);
  }
  .nav-link.is-current .l {
    border-bottom: 1px solid var(--color-acid);
    padding-bottom: 2px;
  }

  .right {
    justify-self: end;
    display: inline-flex;
    gap: 0.5em;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }
  .right .sep {
    color: var(--color-acid);
  }

  .rule {
    border-bottom: 1px solid var(--color-rule);
  }

  @media (max-width: 48rem) {
    .bar {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
      gap: var(--space-2) var(--space-4);
      padding-block: var(--space-3);
    }
    .right {
      display: none;
    }
    .nav {
      grid-column: 1 / -1;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .nav::-webkit-scrollbar {
      display: none;
    }
    .nav ul {
      justify-content: flex-start;
      gap: var(--space-3);
      flex-wrap: nowrap;
      padding-bottom: var(--space-1);
    }
  }
</style>
