---
// Client-only toggle — no props needed.
---

<button
  class="wm-toggle mono"
  id="wm-toggle"
  type="button"
  aria-label="Toggle vertical writing mode"
  aria-pressed="false"
  title="縦書き切替"
>
  <span class="wm-icon" aria-hidden="true"></span>
  <span class="wm-label">TATE</span>
</button>

<script>
  const STORAGE_KEY = 'jct-writing-mode';
  const btn = document.getElementById('wm-toggle') as HTMLButtonElement | null;
  const article = document.querySelector('article.reading') as HTMLElement | null;
  const scrollContainer = document.getElementById('body-scroll') as HTMLElement | null;

  if (btn && article) {
    function scrollToStart() {
      if (!scrollContainer) return;
      // In vertical-rl, text starts at the right edge.
      // After layout reflow, scroll to the rightmost position.
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          scrollContainer.scrollLeft = scrollContainer.scrollWidth - scrollContainer.clientWidth;
        });
      });
    }

    function apply(mode: 'horizontal' | 'vertical', initial = false) {
      article!.dataset.writing = mode;
      btn!.dataset.active = String(mode === 'vertical');
      btn!.setAttribute('aria-pressed', String(mode === 'vertical'));
      const label = btn!.querySelector('.wm-label')!;
      if (label) label.textContent = mode === 'vertical' ? 'YOKO' : 'TATE';

      if (mode === 'vertical') {
        scrollToStart();
      } else if (!initial && scrollContainer) {
        // When switching back to horizontal, reset scroll
        scrollContainer.scrollLeft = 0;
      }
    }

    const saved = localStorage.getItem(STORAGE_KEY);
    apply(saved === 'vertical' ? 'vertical' : 'horizontal', true);

    btn.addEventListener('click', () => {
      const next = article!.dataset.writing === 'vertical' ? 'horizontal' : 'vertical';
      localStorage.setItem(STORAGE_KEY, next);
      apply(next);
    });
  }
</script>

<style>
  .wm-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    text-transform: uppercase;
    color: var(--color-ink-muted);
    padding: 0.4em 0.6em;
    border: 1px solid var(--color-rule);
    border-radius: 0;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
    background: transparent;
    line-height: 1;
  }
  .wm-toggle:hover,
  .wm-toggle:focus-visible {
    color: var(--color-ink);
    border-color: var(--color-acid);
  }
  .wm-toggle[data-active='true'] {
    color: var(--color-acid);
    border-color: var(--color-acid);
  }
  .wm-icon::before {
    content: '縦';
    font-family: var(--font-mincho);
    font-size: 0.85em;
  }
  /* Mobile: keep toggle visible, vertical writing works on touch */
</style>
