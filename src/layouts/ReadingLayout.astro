---
import BaseLayout from './BaseLayout.astro';
import WritingModeToggle from '~/components/WritingModeToggle.astro';

interface Props {
  title: string;
  chapterNumber: number;
  totalChapters: number;
  publishedAt: Date;
  indent?: boolean;
}
const { title, chapterNumber, totalChapters, publishedAt, indent = true } = Astro.props;

const padded = String(chapterNumber).padStart(2, '0');
const totalPad = String(totalChapters).padStart(2, '0');
const dateStr = publishedAt.toISOString().slice(0, 10).replace(/-/g, '.');
---

<BaseLayout title={title} mode="bone" showRouteIndex={false}>
  <article class="reading" data-writing="horizontal" data-indent={String(indent)}>
    <aside class="rail mono" aria-hidden="true">
      <div>ST.{padded}</div>
      <div class="acid">/</div>
      <div>{totalPad}</div>
      <div class="meta-dim">{dateStr}</div>
    </aside>

    <header class="head">
      <div class="head-top">
        <p class="mono">[01 / LEYDA-MONO] · ST.{padded} / {totalPad}</p>
        <WritingModeToggle />
      </div>
      <h1 class="head-title">{title}</h1>
      <p class="mono meta-dim">{dateStr} · OSAKA-SHU</p>
    </header>

    <div class="rule"></div>

    <a class="scroll-anchor mono" id="scroll-anchor-link" href="#body-scroll">▼ LEYDA</a>

    <div class="body-scroll" id="body-scroll">
      <div class="body">
        <h1 class="body-title">{title}</h1>
        <slot />
      </div>
    </div>

    <nav class="pager-bar" id="pager-bar" aria-label="Pagra">
      <button class="pager-btn mono" id="pager-prev" type="button">[←]</button>
      <span class="pager-indicator mono" id="pager-indicator"></span>
      <button class="pager-btn mono" id="pager-next" type="button">[→]</button>
    </nav>

    <div class="rule"></div>

    <slot name="nav" />
  </article>
</BaseLayout>

<script>
  const el = document.getElementById('body-scroll') as HTMLElement | null;
  const article = document.querySelector('article.reading') as HTMLElement | null;
  const prevBtn = document.getElementById('pager-prev');
  const nextBtn = document.getElementById('pager-next');
  const indicator = document.getElementById('pager-indicator');

  // Anchor link: scroll body-scroll top to viewport top
  const anchor = document.getElementById('scroll-anchor-link');
  if (anchor && el) {
    anchor.addEventListener('click', (e) => {
      e.preventDefault();
      const header = document.querySelector('.site-header') as HTMLElement | null;
      const offset = header ? header.offsetHeight : 0;
      const top = el.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: 'smooth' });
    });
  }

  // --- Vertical mode: paginated scroll ---
  if (el && article && prevBtn && nextBtn && indicator) {
    let currentPage = 0;
    let animating = false;

    function isVertical() {
      return article!.dataset.writing === 'vertical';
    }

    function getPageWidth() {
      return el!.clientWidth;
    }

    function getTotalPages() {
      return Math.max(1, Math.ceil(el!.scrollWidth / getPageWidth()));
    }

    // In vertical-rl the first page is at scrollLeft = max (rightmost)
    function getMaxScroll() {
      return el!.scrollWidth - el!.clientWidth;
    }

    function goToPage(page: number) {
      const total = getTotalPages();
      const clamped = Math.max(0, Math.min(page, total - 1));
      if (animating) return;
      currentPage = clamped;

      // vertical-rl: page 0 = rightmost (scrollLeft = max), last page = scrollLeft ≈ 0
      const target = getMaxScroll() - clamped * getPageWidth();
      animating = true;
      el!.scrollTo({ left: target, behavior: 'smooth' });
      setTimeout(() => { animating = false; }, 400);
      updateIndicator();
    }

    function updateIndicator() {
      if (!isVertical()) return;
      const total = getTotalPages();
      indicator!.textContent = `${currentPage + 1} / ${total}`;
      prevBtn!.style.visibility = currentPage <= 0 ? 'hidden' : 'visible';
      nextBtn!.style.visibility = currentPage >= total - 1 ? 'hidden' : 'visible';
    }

    // Buttons: ← = prev page (towards start = right), → = next page (towards left)
    prevBtn.addEventListener('click', () => { if (isVertical()) goToPage(currentPage - 1); });
    nextBtn.addEventListener('click', () => { if (isVertical()) goToPage(currentPage + 1); });

    // Mouse wheel → page turn in vertical mode
    el.addEventListener('wheel', (e) => {
      if (!isVertical()) return;
      if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) return;
      e.preventDefault();
      if (e.deltaY > 0) {
        goToPage(currentPage + 1);
      } else {
        goToPage(currentPage - 1);
      }
    }, { passive: false });

    // Touch swipe for mobile
    let touchStartX = 0;
    el.addEventListener('touchstart', (e) => {
      if (!isVertical()) return;
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    el.addEventListener('touchend', (e) => {
      if (!isVertical()) return;
      const dx = e.changedTouches[0].clientX - touchStartX;
      const threshold = 50;
      if (dx > threshold) {
        // Swiped right → prev page (towards start in vertical-rl)
        goToPage(currentPage - 1);
      } else if (dx < -threshold) {
        // Swiped left → next page
        goToPage(currentPage + 1);
      }
    }, { passive: true });

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (!isVertical()) return;
      if (e.key === 'ArrowLeft' || e.key === ' ') {
        e.preventDefault();
        goToPage(currentPage + 1);
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        goToPage(currentPage - 1);
      }
    });

    // Update on mode change & resize
    const observer = new MutationObserver(() => {
      currentPage = 0;
      requestAnimationFrame(() => {
        if (isVertical()) {
          // Reset to first page (rightmost)
          el!.scrollLeft = getMaxScroll();
        }
        updateIndicator();
      });
    });
    observer.observe(article, { attributes: true, attributeFilter: ['data-writing'] });

    window.addEventListener('resize', () => {
      requestAnimationFrame(() => {
        goToPage(currentPage);
      });
    });

    // Initial
    requestAnimationFrame(() => {
      if (isVertical()) {
        el!.scrollLeft = getMaxScroll();
      }
      updateIndicator();
    });
  }
</script>

<style>
  .reading {
    max-width: var(--max-reading);
    margin-inline: auto;
    display: grid;
    gap: var(--space-8);
    position: relative;
  }
  .rail {
    position: absolute;
    left: calc(var(--max-reading) * -0.22);
    top: 0;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    display: flex;
    flex-direction: row;
    gap: var(--space-3);
    color: var(--color-ink-muted);
  }
  .rail .acid {
    color: var(--color-acid);
  }
  @media (max-width: 60rem) {
    .rail {
      display: none;
    }
  }

  /* --- Header with toggle --- */
  .head {
    display: grid;
    gap: var(--space-4);
  }
  .head-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }
  .head-title {
    font-family: var(--font-mincho);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.3;
  }

  /* Body title: hidden in horizontal, shown in vertical */
  .body-title {
    display: none;
  }
  [data-writing='vertical'] .head-title {
    display: none;
  }
  [data-writing='vertical'] .body-title {
    display: block;
    font-family: var(--font-mincho);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.3;
    margin-block-end: 2em;
  }

  /* --- Scroll anchor (horizontal only) --- */
  .scroll-anchor {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    color: var(--color-ink-muted);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .scroll-anchor:hover,
  .scroll-anchor:focus-visible {
    color: var(--color-acid);
  }
  [data-writing='vertical'] .scroll-anchor {
    display: none;
  }

  /* Scroll target snaps to top edge (below sticky header) */
  .body-scroll {
    scroll-margin-top: 0;
  }

  /* --- Body (horizontal mode — default) --- */
  .body {
    font-family: var(--font-mincho);
    font-size: var(--fs-reading);
    line-height: var(--lh-reading);
    letter-spacing: var(--ls-reading);
  }
  .body :global(p) {
    text-indent: 1em;
    margin-block: 1.4em;
  }
  [data-indent='false'] .body :global(p) {
    text-indent: 0;
  }
  .body :global(p[data-no-indent]) {
    text-indent: 0;
  }
  .body :global(p:first-child) {
    margin-top: 0;
  }
  @media (min-width: 64rem) {
    .body {
      font-size: 1.125rem;
    }
  }

  /* --- Horizontal mode: normal scroll, no pagination --- */
  [data-writing='horizontal'] .body-scroll {
    /* pass-through — normal page scroll */
  }
  [data-writing='horizontal'] .pager-bar {
    display: none;
  }

  /* Pager bar (vertical only) */
  .pager-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    padding-block: var(--space-3);
  }
  .pager-btn {
    color: var(--color-ink-muted);
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .pager-btn:hover,
  .pager-btn:focus-visible {
    color: var(--color-acid);
  }
  .pager-indicator {
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    color: var(--color-ink-muted);
  }

  /* --- Vertical writing mode (paginated) --- */
  [data-writing='vertical'] .body-scroll {
    height: var(--height-reading-v);
    overflow-x: hidden;
    overflow-y: hidden;
    overscroll-behavior-x: contain;
    position: relative;
  }

  [data-writing='vertical'] .body {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    line-break: strict;
    word-break: normal;
    overflow-wrap: break-word;
    height: 100%;
    width: max-content;
    padding-inline: var(--space-8);
    padding-block: var(--space-4);
  }

  [data-writing='vertical'] .body :global(p) {
    text-indent: 1em;
    margin-block: 1.4em;
  }
  [data-indent='false'][data-writing='vertical'] .body :global(p) {
    text-indent: 0;
  }

  [data-writing='vertical'] .body :global(p:first-child) {
    margin-top: 0;
  }

  /* Tate-chu-yoko — only active in vertical mode */
  [data-writing='vertical'] .body :global(.tcy) {
    text-combine-upright: all;
    -webkit-text-combine: horizontal;
  }

  /* Code blocks — stay horizontal in vertical mode */
  [data-writing='vertical'] .body :global(pre) {
    writing-mode: horizontal-tb;
    text-orientation: initial;
    display: block;
    max-width: none;
    max-height: 24rem;
    overflow-x: auto;
    overflow-y: auto;
    margin-block: 1.5em;
    padding: var(--space-4);
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-ink) 8%);
    border: 1px solid var(--color-rule);
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    letter-spacing: 0;
    white-space: pre;
    tab-size: 2;
  }
  [data-writing='vertical'] .body :global(code) {
    writing-mode: horizontal-tb;
    text-orientation: initial;
  }

  /* Code blocks — horizontal mode */
  .body :global(pre) {
    overflow-x: auto;
    margin-block: 1.5em;
    padding: var(--space-4);
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-ink) 8%);
    border: 1px solid var(--color-rule);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    letter-spacing: 0;
    tab-size: 2;
  }
  .body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
  }
  .body :global(:not(pre) > code) {
    padding: 0.15em 0.35em;
    background: color-mix(in srgb, var(--color-bg) 88%, var(--color-ink) 12%);
    border: 1px solid var(--color-rule);
  }

  /* Quote figure (blockquote with caption) */
  .body :global(.quote-figure) {
    margin-block: 2em;
    padding: 0;
  }
  .body :global(.quote-figure blockquote) {
    margin: 0;
    padding-inline-start: 1.5em;
    border-inline-start: 2px solid var(--color-acid);
    font-style: italic;
  }
  .body :global(.quote-figure blockquote p) {
    text-indent: 0;
  }
  .body :global(.quote-figure figcaption) {
    margin-top: 0.75em;
    padding-inline-start: 1.5em;
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    color: var(--color-ink-muted);
    font-style: normal;
  }
  .body :global(.quote-figure figcaption p) {
    text-indent: 0;
    margin: 0;
  }

  /* Quote figure — vertical mode */
  [data-writing='vertical'] .body :global(.quote-figure blockquote) {
    border-inline-start: none;
    border-block-start: 2px solid var(--color-acid);
    padding-inline-start: 0;
    padding-block-start: 1.5em;
  }
  [data-writing='vertical'] .body :global(.quote-figure figcaption) {
    padding-inline-start: 0;
    padding-block-start: 0.5em;
  }

  /* Scroll fade hint (left edge) */
  [data-writing='vertical'] .body-scroll::after {
    content: '';
    position: sticky;
    left: 0;
    top: 0;
    width: 2rem;
    height: 100%;
    background: linear-gradient(to right, var(--color-bg), transparent);
    pointer-events: none;
    display: block;
    flex-shrink: 0;
  }
</style>
