---
import BaseLayout from './BaseLayout.astro';
import WritingModeToggle from '~/components/WritingModeToggle.astro';

interface Props {
  title: string;
  chapterNumber: number;
  totalChapters: number;
  publishedAt: Date;
}
const { title, chapterNumber, totalChapters, publishedAt } = Astro.props;

const padded = String(chapterNumber).padStart(2, '0');
const totalPad = String(totalChapters).padStart(2, '0');
const dateStr = publishedAt.toISOString().slice(0, 10).replace(/-/g, '.');
---

<BaseLayout title={title} mode="bone" showRouteIndex={false}>
  <article class="reading" data-writing="horizontal">
    <aside class="rail mono" aria-hidden="true">
      <div>CH.{padded}</div>
      <div class="acid">/</div>
      <div>{totalPad}</div>
      <div class="meta-dim">{dateStr}</div>
    </aside>

    <header class="head">
      <div class="head-top">
        <p class="mono">[01 / NOVEL] · CH.{padded} / {totalPad}</p>
        <WritingModeToggle />
      </div>
      <h1>{title}</h1>
      <p class="mono meta-dim">{dateStr} · TOKYO</p>
    </header>

    <div class="rule"></div>

    <div class="body-scroll" id="body-scroll">
      <div class="body">
        <slot />
      </div>
    </div>

    <div class="rule"></div>

    <slot name="nav" />
  </article>
</BaseLayout>

<script>
  import { initVerticalScroll } from '~/scripts/vertical-scroll';
  const el = document.getElementById('body-scroll');
  if (el) initVerticalScroll(el);
</script>

<style>
  .reading {
    max-width: var(--max-reading);
    margin-inline: auto;
    display: grid;
    gap: var(--space-8);
    position: relative;
  }
  .rail {
    position: absolute;
    left: calc(var(--max-reading) * -0.22);
    top: 0;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    display: flex;
    flex-direction: row;
    gap: var(--space-3);
    color: var(--color-ink-muted);
  }
  .rail .acid {
    color: var(--color-acid);
  }
  @media (max-width: 60rem) {
    .rail {
      display: none;
    }
  }

  /* --- Header with toggle --- */
  .head {
    display: grid;
    gap: var(--space-4);
  }
  .head-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }
  .head h1 {
    font-family: var(--font-mincho);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.3;
  }

  /* --- Body (horizontal mode — default) --- */
  .body {
    font-family: var(--font-mincho);
    font-size: clamp(1rem, 1.1vw + 0.85rem, 1.2rem);
    line-height: var(--lh-reading-tight);
    letter-spacing: clamp(0.03em, 0.08vw, 0.055em);
    max-width: 36ch;
  }
  .body :global(p) {
    text-indent: 1em;
    margin-block: 1.25em;
  }
  .body :global(p:first-child) {
    margin-top: 0;
  }
  @media (min-width: 64rem) {
    .body {
      line-height: var(--lh-reading);
    }
  }

  /* --- Scroll container (no effect in horizontal) --- */
  [data-writing='horizontal'] .body-scroll {
    /* pass-through */
  }

  /* --- Vertical writing mode --- */
  [data-writing='vertical'] .body-scroll {
    height: var(--height-reading-v);
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-x: contain;
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: var(--color-rule-strong) transparent;
    position: relative;
  }

  [data-writing='vertical'] .body {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    line-break: strict;
    word-break: normal;
    overflow-wrap: break-word;
    height: 100%;
    width: max-content;
    padding-inline: var(--space-8);
    padding-block: var(--space-6);
    line-height: var(--lh-reading-loose);
    letter-spacing: clamp(0.045em, 0.08vw, 0.07em);
  }

  [data-writing='vertical'] .body :global(p) {
    text-indent: 1em;
    margin-block: 1.35em;
  }

  [data-writing='vertical'] .body :global(p:first-child) {
    margin-top: 0;
  }

  /* Tate-chu-yoko — only active in vertical mode */
  [data-writing='vertical'] .body :global(.tcy) {
    text-combine-upright: all;
    -webkit-text-combine: horizontal;
  }

  /* Code blocks — stay horizontal in vertical mode */
  [data-writing='vertical'] .body :global(pre) {
    writing-mode: horizontal-tb;
    text-orientation: initial;
    display: block;
    max-width: none;
    max-height: 24rem;
    overflow-x: auto;
    overflow-y: auto;
    margin-block: 1.5em;
    padding: var(--space-4);
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-ink) 8%);
    border: 1px solid var(--color-rule);
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    letter-spacing: 0;
    white-space: pre;
    tab-size: 2;
  }
  [data-writing='vertical'] .body :global(code) {
    writing-mode: horizontal-tb;
    text-orientation: initial;
  }

  /* Code blocks — horizontal mode */
  .body :global(pre) {
    overflow-x: auto;
    margin-block: 1.5em;
    padding: var(--space-4);
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-ink) 8%);
    border: 1px solid var(--color-rule);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    letter-spacing: 0;
    tab-size: 2;
  }
  .body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
  }
  .body :global(:not(pre) > code) {
    padding: 0.15em 0.35em;
    background: color-mix(in srgb, var(--color-bg) 88%, var(--color-ink) 12%);
    border: 1px solid var(--color-rule);
  }

  /* Scroll fade hint (left edge) */
  [data-writing='vertical'] .body-scroll::after {
    content: '';
    position: sticky;
    left: 0;
    top: 0;
    width: 2rem;
    height: 100%;
    background: linear-gradient(to right, var(--color-bg), transparent);
    pointer-events: none;
    display: block;
    flex-shrink: 0;
  }
</style>
