---
import BaseLayout from './BaseLayout.astro';
import WritingModeToggle from '~/components/WritingModeToggle.astro';
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import {
  absoluteUrl,
  buildArticleNode,
  buildBreadcrumbNode,
} from '~/lib/jsonld';

interface Props {
  title: string;
  chapterNumber: number;
  totalChapters: number;
  publishedAt: Date;
  indent?: boolean;
  series?: string;
  description?: string;
  heroImage?: ImageMetadata;
  heroAlt?: string;
  heroCaption?: string;
  heroAspect?: '16:9' | '4:3' | '3:2' | '1:1';
}
const {
  title,
  chapterNumber,
  totalChapters,
  publishedAt,
  indent = true,
  series,
  description,
  heroImage,
  heroAlt,
  heroCaption,
  heroAspect = '16:9',
} = Astro.props;
const heroClass = `chapter-hero hero-${heroAspect.replace(':', '-')}`;

const padded = String(chapterNumber).padStart(2, '0');
const totalPad = String(totalChapters).padStart(2, '0');
const dateStr = publishedAt.toISOString().slice(0, 10).replace(/-/g, '.');

// Map series label to a slug used on the article element for series-specific
// visual treatment, and decide whether to enable marginalia layout.
const seriesSlug = (() => {
  switch (series) {
    case '脚注の王':
      return 'footnote-king';
    case '泥の断章':
      return 'mud-fragments';
    case '短編':
      return 'shorts';
    case '長編':
      return 'long-form';
    default:
      return 'main';
  }
})();
const marginalia = seriesSlug === 'footnote-king' ? 'on' : 'off';

// Build JSON-LD for this chapter. Article + Breadcrumb cover search indexing
// and rich-results eligibility. Hero image (if present) becomes og:image
// and also the Article.image property.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.pathname;
const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? '';
const siteUrl = Astro.site ? new URL(base + '/', Astro.site).toString() : '';
const novelIndexUrl = Astro.site
  ? new URL(`${base}/novel/`, Astro.site).toString()
  : `${base}/novel/`;

let articleImageUrl: string | undefined;
if (heroImage) {
  const processed = await getImage({ src: heroImage, width: 1200, height: 630, format: 'jpg' });
  articleImageUrl = absoluteUrl(processed.src, Astro.site);
}

const jsonLdNodes = [
  buildArticleNode({
    url: canonicalUrl,
    headline: title,
    description,
    datePublished: publishedAt.toISOString().slice(0, 10),
    articleSection: series,
    imageUrl: articleImageUrl,
    siteOrigin,
  }),
  buildBreadcrumbNode([
    { name: 'juicetopia', url: siteUrl || canonicalUrl },
    { name: '小説', url: novelIndexUrl },
    ...(series
      ? [{ name: series, url: novelIndexUrl }]
      : []),
    { name: title, url: canonicalUrl },
  ]),
];
---

<BaseLayout
  title={title}
  description={description}
  mode="bone"
  showRouteIndex={false}
  ogImage={heroImage}
  ogImageAlt={heroAlt ?? title}
  jsonLdNodes={jsonLdNodes}
>
  <article
    class="reading"
    data-writing="horizontal"
    data-indent={String(indent)}
    data-series={seriesSlug}
    data-marginalia={marginalia}
  >
    <aside class="rail mono" aria-hidden="true">
      <div>ST.{padded}</div>
      <div class="acid">/</div>
      <div>{totalPad}</div>
      <div class="meta-dim">{dateStr}</div>
    </aside>

    <header class="head">
      <span class="chapter-watermark" aria-hidden="true">{padded}</span>
      <div class="head-top">
        <p class="mono">[01 / LEYDA-MONO] · ST.{padded} / {totalPad}</p>
        <WritingModeToggle />
      </div>
      <h1 class="head-title">{title}</h1>
      <p class="mono meta-dim">{dateStr} · OSAKA-SHU</p>
    </header>

    {heroImage && (
      <figure class={heroClass} data-reveal>
        <div class="hero-frame">
          <Image
            src={heroImage}
            alt={heroAlt ?? title}
            widths={[640, 960, 1280]}
            sizes="(min-width: 48rem) 40rem, 90vw"
          />
        </div>
        {heroCaption && <figcaption class="mono">{heroCaption}</figcaption>}
      </figure>
    )}

    <div class="rule"></div>

    <a class="scroll-anchor mono" id="scroll-anchor-link" href="#body-scroll">▼ LEYDA</a>

    <div class="body-scroll" id="body-scroll">
      <div class="body">
        <h1 class="body-title">{title}</h1>
        <slot />
      </div>
    </div>

    <div class="rule"></div>

    <slot name="nav" />
  </article>
</BaseLayout>

<script>
  import { initVerticalScroll } from '~/scripts/vertical-scroll';
  import '~/scripts/marginalia';
  import '~/scripts/vertical-parallax';
  const el = document.getElementById('body-scroll');
  if (el) initVerticalScroll(el);

  // Anchor link: scroll body-scroll top to viewport top
  const anchor = document.getElementById('scroll-anchor-link');
  if (anchor && el) {
    anchor.addEventListener('click', (e) => {
      e.preventDefault();
      const header = document.querySelector('.site-header') as HTMLElement | null;
      const offset = header ? header.offsetHeight : 0;
      const top = el.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: 'smooth' });
    });
  }
</script>

<style>
  .reading {
    max-width: var(--max-reading);
    margin-inline: auto;
    display: grid;
    gap: var(--space-8);
    position: relative;
  }
  /* Vertical mode immersion rules live in src/styles/base.css so they can
     reach slot-provided children (ChapterNav) without Astro scoping. */
  .rail {
    position: absolute;
    left: calc(var(--max-reading) * -0.22);
    top: 0;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    display: flex;
    flex-direction: row;
    gap: var(--space-3);
    color: var(--color-ink-muted);
  }
  .rail .acid {
    color: var(--color-acid-ink);
  }
  @media (max-width: 60rem) {
    .rail {
      display: none;
    }
  }

  /* --- Header with toggle --- */
  .head {
    display: grid;
    gap: var(--space-4);
  }
  .head-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
  }
  .head {
    position: relative;
    overflow: hidden;
  }
  .chapter-watermark {
    position: absolute;
    top: -0.15em;
    right: -0.05em;
    font-family: var(--font-display);
    font-size: clamp(8rem, 20vw, 16rem);
    font-weight: 400;
    line-height: 1;
    color: var(--color-ink);
    opacity: 0.04;
    pointer-events: none;
    user-select: none;
  }
  .head-title {
    font-family: var(--font-mincho);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.3;
    position: relative;
  }

  /* Body title: hidden in horizontal, shown in vertical */
  .body-title {
    display: none;
  }
  [data-writing='vertical'] .head-title {
    display: none;
  }
  [data-writing='vertical'] .body-title {
    display: block;
    font-family: var(--font-mincho);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.3;
    margin-block-end: 2em;
  }

  /* --- Scroll anchor (horizontal only) --- */
  .scroll-anchor {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    color: var(--color-ink-muted);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .scroll-anchor:hover,
  .scroll-anchor:focus-visible {
    color: var(--color-acid-ink);
  }
  [data-writing='vertical'] .scroll-anchor {
    display: none;
  }

  /* Scroll target snaps to top edge (below sticky header) */
  .body-scroll {
    scroll-margin-top: 0;
  }

  /* --- Body (horizontal mode — default) --- */
  .body {
    font-family: var(--font-mincho);
    font-size: var(--fs-reading);
    line-height: var(--lh-reading);
    letter-spacing: var(--ls-reading);
  }
  .body :global(p) {
    text-indent: 1em;
    margin-block: 1.4em;
  }
  [data-indent='false'] .body :global(p) {
    text-indent: 0;
  }
  .body :global(p[data-no-indent]) {
    text-indent: 0;
  }
  .body :global(p:first-child) {
    margin-top: 0;
  }
  @media (min-width: 64rem) {
    .body {
      font-size: 1.125rem;
    }
  }

  /* --- Horizontal mode: normal scroll --- */
  [data-writing='horizontal'] .body-scroll {
    /* pass-through — normal page scroll */
  }

  /* --- Vertical writing mode --- */
  [data-writing='vertical'] .body-scroll {
    height: var(--height-reading-v);
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-x: contain;
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: var(--color-acid-dim) transparent;
    position: relative;
  }

  [data-writing='vertical'] .body {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    line-break: strict;
    word-break: normal;
    overflow-wrap: break-word;
    height: 100%;
    width: max-content;
    padding-inline: var(--space-8);
    padding-block: var(--space-4);
  }

  [data-writing='vertical'] .body :global(p) {
    text-indent: 1em;
    margin-block: 1.4em;
  }
  [data-indent='false'][data-writing='vertical'] .body :global(p) {
    text-indent: 0;
  }
  /* Japanese typesetting rule — paragraphs that open with a bracket
     (「『( tagged via remark-no-indent as data-no-indent) don't take
     the 1em indent, because the bracket glyph itself carries visual lead-in. */
  [data-writing='vertical'] .body :global(p[data-no-indent]) {
    text-indent: 0;
  }

  [data-writing='vertical'] .body :global(p:first-child) {
    margin-top: 0;
  }

  /* Tate-chu-yoko — only active in vertical mode */
  [data-writing='vertical'] .body :global(.tcy) {
    text-combine-upright: all;
    -webkit-text-combine: horizontal;
  }

  /* Code blocks — stay horizontal in vertical mode */
  [data-writing='vertical'] .body :global(pre) {
    writing-mode: horizontal-tb;
    text-orientation: initial;
    display: block;
    max-width: none;
    max-height: 24rem;
    overflow-x: auto;
    overflow-y: auto;
    margin-block: 1.5em;
    padding: var(--space-4);
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-ink) 8%);
    border: 1px solid var(--color-rule);
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    letter-spacing: 0;
    white-space: pre;
    tab-size: 2;
  }
  [data-writing='vertical'] .body :global(code) {
    writing-mode: horizontal-tb;
    text-orientation: initial;
  }

  /* Code blocks — horizontal mode */
  .body :global(pre) {
    overflow-x: auto;
    margin-block: 1.5em;
    padding: var(--space-4);
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-ink) 8%);
    border: 1px solid var(--color-rule);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    letter-spacing: 0;
    tab-size: 2;
  }
  .body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
  }
  .body :global(:not(pre) > code) {
    padding: 0.15em 0.35em;
    background: color-mix(in srgb, var(--color-bg) 88%, var(--color-ink) 12%);
    border: 1px solid var(--color-rule);
  }

  /* HR → dot separator */
  .body :global(hr) {
    border: none;
    text-align: center;
    margin-block: 2em;
    height: auto;
  }
  .body :global(hr)::after {
    content: '· · ·';
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: 0.5em;
    color: var(--color-ink-muted);
  }

  /* Blockquote (引用) — acid accent line on every `> text` block, whether
     or not it has a `——` caption. The caption form (remark-blockquote-caption
     wraps it in <figure class="quote-figure">) just adds the figcaption
     styling on top of this shared base. */
  .body :global(blockquote) {
    margin-block: 2em;
    padding-left: 1em;
    border-left: 2px solid var(--color-acid);
  }
  .body :global(blockquote p) {
    text-indent: 0;
    /* Preserve source line breaks — writers use stacked `> line` rows as
       poetic enumeration, not as a single reflowed paragraph. Consecutive
       spaces still collapse to one.
       NOTE: applied to the <p> rather than the <blockquote> so that the
       markdown-emitted whitespace between <blockquote> and <p> (which would
       otherwise render as blank leading/trailing rows in vertical mode)
       stays collapsed. */
    white-space: pre-line;
  }

  /* Figure wrapper for the `——` caption form. Let the figure own the outer
     margin so the inner blockquote hugs tight to the caption below. */
  .body :global(.quote-figure) {
    margin-block: 2em;
    padding: 0;
  }
  .body :global(.quote-figure blockquote) {
    margin: 0;
  }
  .body :global(.quote-figure figcaption) {
    margin-top: 0.75em;
    padding-inline-start: 1.5em;
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    color: var(--color-ink-muted);
    font-style: normal;
  }
  .body :global(.quote-figure figcaption p) {
    text-indent: 0;
    margin: 0;
  }

  /* Vertical mode — in tategaki the "start of the line" is the TOP edge,
     so the acid accent moves from left to top. Applies to every blockquote,
     captioned or plain. */
  [data-writing='vertical'] .body :global(blockquote) {
    border-left: none;
    border-top: 2px solid var(--color-acid);
    padding-left: 0;
    padding-top: 1em;
  }
  [data-writing='vertical'] .body :global(.quote-figure figcaption) {
    padding-top: 0;
  }

  /* Scroll fade hint (left edge) */
  [data-writing='vertical'] .body-scroll::after {
    content: '';
    position: sticky;
    left: 0;
    top: 0;
    width: 2rem;
    height: 100%;
    background: linear-gradient(to right, var(--color-bg), transparent);
    pointer-events: none;
    display: block;
    flex-shrink: 0;
  }

  /* ============================================================
     Series-specific accents — tint the chapter mark / rail / rules
     without overriding the global chartreuse accent elsewhere.
     ============================================================ */

  /* 脚注の王 — ink red: legislation, seals, stamps */
  .reading[data-series='footnote-king'] {
    --series-tint: #c0331a;
    --series-tint-dim: rgba(192, 51, 26, 0.45);
  }
  .reading[data-series='footnote-king'] .rail .acid,
  .reading[data-series='footnote-king'] .chapter-watermark {
    color: var(--series-tint);
  }
  .reading[data-series='footnote-king'] .chapter-watermark {
    opacity: 0.06;
  }
  .reading[data-series='footnote-king'] .rule {
    border-bottom-color: var(--series-tint-dim);
  }

  /* 泥の断章 — mud brown: sediment, soil */
  .reading[data-series='mud-fragments'] {
    --series-tint: #6b4a2b;
    --series-tint-dim: rgba(107, 74, 43, 0.45);
  }
  .reading[data-series='mud-fragments'] .rail .acid,
  .reading[data-series='mud-fragments'] .chapter-watermark {
    color: var(--series-tint);
  }
  .reading[data-series='mud-fragments'] .chapter-watermark {
    opacity: 0.05;
  }

  /* Shorts + long form stay on the default acid accent. */

  /* ============================================================
     Chapter hero figure — sits between the header and body.
     Aspect ratio matches the heroAspect prop; image is cropped to
     cover via object-fit. Caption below, mono/meta styled.
     ============================================================ */
  .chapter-hero {
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }
  .chapter-hero .hero-frame {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-rule);
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-ink) 8%);
  }
  .chapter-hero.hero-16-9 .hero-frame { aspect-ratio: 16 / 9; }
  .chapter-hero.hero-4-3 .hero-frame { aspect-ratio: 4 / 3; }
  .chapter-hero.hero-3-2 .hero-frame { aspect-ratio: 3 / 2; }
  .chapter-hero.hero-1-1 .hero-frame { aspect-ratio: 1 / 1; }
  .chapter-hero .hero-frame :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .chapter-hero figcaption {
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    color: var(--color-ink-muted);
    padding-inline-start: 1em;
    border-inline-start: 1px solid var(--color-acid-dim);
  }

  /* ============================================================
     Marginalia / sidenotes (for [data-marginalia='on'])
     Activated at min-width: 80rem — otherwise falls back to the
     default GFM footnote section rendered inline at the bottom.
     ============================================================ */

  .body :global(sup[class*='footnote-ref']) {
    font-family: var(--font-mono);
    font-size: 0.58em;
    letter-spacing: 0.04em;
    vertical-align: super;
    line-height: 0;
    margin-inline-start: 0.1em;
  }
  .body :global(sup[class*='footnote-ref'] a) {
    color: var(--series-tint, var(--color-acid));
    text-decoration: none;
    border-bottom: none;
    padding: 0 0.15em;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .body :global(sup[class*='footnote-ref'] a:hover),
  .body :global(sup[class*='footnote-ref'] a:focus-visible) {
    background: color-mix(
      in srgb,
      var(--color-bg) 86%,
      var(--series-tint, var(--color-acid)) 14%
    );
  }

  /* Default GFM footnote section — keep visible on narrow screens.
     We hide it via CSS only when the marginalia layout has actually
     taken over (wide screen + [data-has-footnotes]). */
  .body :global(.footnotes) {
    margin-top: 4em;
    padding-top: 1.5em;
    border-top: 1px solid var(--color-rule);
    font-size: 0.875rem;
  }
  .body :global(.footnotes h2) {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    color: var(--color-ink-muted);
    text-transform: uppercase;
    margin-bottom: 1em;
  }
  .body :global(.footnotes ol) {
    padding-inline-start: 1.5em;
  }
  .body :global(.footnotes li) {
    margin-block: 0.8em;
    line-height: 1.8;
  }

  /* Sidenote column — rendered by scripts/marginalia.ts on wide screens */
  .reading .body-scroll {
    position: relative;
  }
  .reading :global(.sidenote-col) {
    position: absolute;
    top: 0;
    left: calc(100% + var(--space-6));
    width: 14rem;
    pointer-events: none;
    display: none;
  }
  .reading :global(.sidenote) {
    position: absolute;
    right: 0;
    width: 14rem;
    font-family: var(--font-mincho);
    font-size: 0.8125rem;
    line-height: 1.65;
    letter-spacing: 0.02em;
    color: var(--color-ink-muted);
    padding-inline-start: var(--space-3);
    border-inline-start: 1px solid var(--series-tint-dim, var(--color-rule-strong));
    pointer-events: auto;
  }
  .reading :global(.sidenote p) {
    margin: 0;
    text-indent: 0 !important;
  }
  .reading :global(.sidenote .sidenote-num) {
    display: inline-block;
    margin-inline-end: 0.4em;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    color: var(--series-tint, var(--color-acid));
    vertical-align: super;
  }

  /* Activate sidenote column on wide screens when article has footnotes.
     Hide the default bottom footnote section to avoid duplication. */
  @media (min-width: 80rem) {
    .reading[data-marginalia='on'][data-has-footnotes='true'] :global(.sidenote-col) {
      display: block;
    }
    .reading[data-marginalia='on'][data-has-footnotes='true'] .body :global(.footnotes) {
      display: none;
    }
  }

  /* Vertical writing mode turns off marginalia entirely (would fight tate). */
  [data-writing='vertical'] :global(.sidenote-col) {
    display: none !important;
  }
  [data-writing='vertical'][data-marginalia='on'][data-has-footnotes='true']
    .body :global(.footnotes) {
    display: block;
  }
</style>
