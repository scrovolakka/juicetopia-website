---
import '~/styles/tokens.css';
import '~/styles/base.css';
import '~/styles/effects.css';
import '~/styles/utilities.css';

import SiteHeader from '~/components/SiteHeader.astro';
import SiteFooter from '~/components/SiteFooter.astro';
import RouteIndex from '~/components/RouteIndex.astro';
import { modeFor, routeIndex } from '~/lib/nav';
import {
  buildPublisherNode,
  buildWebSiteNode,
  toJsonLdGraph,
} from '~/lib/jsonld';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title?: string;
  description?: string;
  mode?: 'bone' | 'void';
  showRouteIndex?: boolean;
  /**
   * Optional OG / Twitter Card image. Processed to 1200×630 JPG (the generally
   * accepted "summary_large_image" size). If omitted, no og:image is emitted.
   */
  ogImage?: ImageMetadata;
  ogImageAlt?: string;
  /**
   * Additional JSON-LD nodes to be merged into the per-page @graph alongside
   * the site-wide WebSite/Publisher pair. Use helpers in `~/lib/jsonld.ts`.
   */
  jsonLdNodes?: Array<Record<string, unknown>>;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname.replace(base, '') || '/';
const autoMode = modeFor(path);
const {
  title,
  description,
  mode = autoMode,
  showRouteIndex = true,
  ogImage,
  ogImageAlt,
  jsonLdNodes = [],
} = Astro.props;

const pageTitle = title ? `${title} — juicetopia` : 'juicetopia';
const desc = description ?? 'juicetopia — pana-di leyda-mono & montra-mesa.';
const current = routeIndex(path);
const grainHref = `${base}/grain.svg`;

// Build absolute URLs for OG / canonical. Astro.site must be set in
// astro.config.mjs (it is: https://scrovolakka.github.io).
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

let ogImageUrl: string | undefined;
let ogImageWidth: number | undefined;
let ogImageHeight: number | undefined;
if (ogImage) {
  const processed = await getImage({
    src: ogImage,
    width: 1200,
    height: 630,
    format: 'jpg',
    // fit: 'cover' would be nice but sharp defaults handle most cases; with
    // width+height set, astro/sharp crops/fits as needed.
  });
  ogImageUrl = new URL(processed.src, Astro.site).toString();
  ogImageWidth = processed.attributes.width ?? 1200;
  ogImageHeight = processed.attributes.height ?? 630;
}

// JSON-LD @graph: site-wide WebSite + Publisher are always present; per-page
// additions (Article, DefinedTerm, BreadcrumbList, etc.) come in via props.
const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? '';
const siteUrl = Astro.site
  ? new URL(import.meta.env.BASE_URL, Astro.site).toString()
  : '';
const jsonLd = toJsonLdGraph([
  buildWebSiteNode(siteOrigin, siteUrl),
  buildPublisherNode(siteOrigin),
  ...jsonLdNodes,
]);
---

<!doctype html>
<html lang="ja" data-mode={mode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    <!-- Fonts: Space Grotesk, JetBrains Mono, Shippori Mincho B1, Noto Sans JP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans+JP:wght@300;400;500&family=Shippori+Mincho+B1:wght@400;500&family=Space+Grotesk:wght@400;500&display=swap"
    />

    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="juicetopia" />
    <meta property="og:locale" content="ja_JP" />
    {ogImageUrl && (
      <>
        <meta property="og:image" content={ogImageUrl} />
        {ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
        {ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
        {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content={ogImageUrl} />
        {ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}
      </>
    )}
    {!ogImageUrl && <meta name="twitter:card" content="summary" />}
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="generator" content={Astro.generator} />

    <script type="application/ld+json" set:html={jsonLd} />
  </head>
  <body style={`--grain-url: url('${grainHref}');`}>
    <a class="skip-link" href="#main">スキップして本文へ</a>
    <div class="fx-scanlines" aria-hidden="true"></div>
    <div class="fx-grain" aria-hidden="true"></div>
    <div id="fx-sweep" class="fx-sweep" aria-hidden="true"></div>

    <SiteHeader />

    <main id="main" class="page page-fade">
      {
        showRouteIndex && current && (
          <div class="page-column route-head">
            <RouteIndex id={current.id} label={current.label} />
          </div>
        )
      }
      <slot />
    </main>

    <SiteFooter />

    <script>
      import '~/scripts/scroll-reveal';
    </script>
    <script>
      // Trigger sweep on internal link clicks (skip modifier keys and external / hash)
      const sweep = document.getElementById('fx-sweep');
      const reduce = matchMedia('(prefers-reduced-motion: reduce)');
      document.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement)?.closest('a');
        if (!target) return;
        if (reduce.matches) return;
        const href = target.getAttribute('href') ?? '';
        if (!href || href.startsWith('#')) return;
        if (target.target === '_blank') return;
        const url = new URL(href, location.href);
        if (url.origin !== location.origin) return;
        if (!sweep) return;
        sweep.classList.remove('is-running');
        // Force reflow to restart animation
        void sweep.offsetWidth;
        sweep.classList.add('is-running');
      });
    </script>
  </body>
</html>

<style>
  .route-head {
    margin-bottom: var(--space-8);
  }
</style>
