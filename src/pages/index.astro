---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroCanvas from '~/components/HeroCanvas.astro';
import Logotype from '~/components/Logotype.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const [novel, gallery, characters, codex, lexicon, cronika] = await Promise.all([
  getCollection('novel'),
  getCollection('gallery'),
  getCollection('characters'),
  getCollection('codex'),
  getCollection('lexicon'),
  getCollection('cronika'),
]);

const pad = (n: number) => String(n).padStart(2, '0');
const fmt = (d: Date) => d.toISOString().slice(0, 10).replace(/-/g, '.');

const nodes = [
  { count: pad(novel.length), label: 'LEYDA', jp: '章', href: `${base}/novel/` },
  { count: pad(gallery.length), label: 'PANA', jp: '画', href: `${base}/gallery/` },
  { count: pad(characters.length), label: 'NOMA', jp: '人', href: `${base}/characters/` },
  { count: pad(codex.length), label: 'MONDO', jp: '注', href: `${base}/mondo/` },
  { count: pad(lexicon.length), label: 'LEKSIKO', jp: '語', href: `${base}/lexicon/` },
];

const latestChapter = novel
  .slice()
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())[0];
const latestCronika = cronika
  .slice()
  .sort((a, b) => b.data.loggedAt.getTime() - a.data.loggedAt.getTime())[0];

const lastUpdateDate = [
  latestChapter?.data.publishedAt,
  latestCronika?.data.loggedAt,
].filter(Boolean).sort((a: any, b: any) => b.getTime() - a.getTime())[0] as Date | undefined;
const lastUpdateStr = lastUpdateDate ? fmt(lastUpdateDate) : '—';
---

<BaseLayout mode="void" showRouteIndex={false}>
  <section class="ix">
    <div class="ix-canvas">
      <HeroCanvas />
    </div>

    <div class="ix-center">
      <div class="ix-meta mono">
        <span>[00 / MOKURO]</span>
        <span class="sep">·</span>
        <span>VOLA 001</span>
      </div>
      <Logotype size="hero" href={`${base}/`} />
      <p class="ix-tagline">
        <span class="jp">電子果汁アーカイブ</span>
      </p>
    </div>

    <nav class="ix-nodes" id="node-nav" aria-label="Banda">
      {nodes.map((n, i) => (
        <a class="ix-node" data-node-idx={i} href={n.href}>
          <span class="ix-node-count">{n.count}</span>
          <span class="ix-node-label">{n.label}</span>
          <span class="ix-node-jp">{n.jp}</span>
        </a>
      ))}
    </nav>

    <div class="ix-strip mono">
      <span class="ix-strip-dot" aria-hidden="true"></span>
      <span>NUN</span>
      <span class="sep">·</span>
      <span>{lastUpdateStr}</span>
      {latestChapter && (
        <>
          <span class="sep">·</span>
          <a href={`${base}/novel/${latestChapter.slug}/`}>
            ST.{pad(latestChapter.data.chapterNumber)}「{latestChapter.data.title}」
          </a>
        </>
      )}
      {latestCronika && (
        <>
          <span class="sep">·</span>
          <a href={`${base}/cronika/#${latestCronika.slug}`}>
            {latestCronika.data.title}
          </a>
        </>
      )}
    </div>

    <div class="ix-foot mono">
      <span>JCT</span>
      <span class="sep">·</span>
      <span>PANA-DI-BANDA-KA-FORNA-MODA-NE-NEK</span>
    </div>
  </section>
</BaseLayout>

<style>
  :global(body) {
    overflow: hidden;
    height: 100dvh;
  }
  :global(.site-footer) {
    display: none;
  }
  :global(#main.page) {
    padding: 0;
    margin: 0;
    animation: none;
  }

  .ix {
    position: fixed;
    inset: 0;
    display: grid;
    grid-template-rows: 1fr auto auto;
    overflow: hidden;
  }

  .ix-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .ix-canvas :global(.hero-wrap) {
    max-width: none;
    max-height: none;
    aspect-ratio: auto;
    width: 100%;
    height: 100%;
  }

  .ix-center {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    pointer-events: none;
    grid-row: 1;
    align-self: start;
    padding-top: clamp(3rem, 8vh, 7rem);
  }
  .ix-center :global(.logo) {
    pointer-events: auto;
  }

  .ix-meta {
    display: flex;
    gap: 0.5em;
    color: var(--color-ink-muted);
    font-size: var(--fs-meta);
    letter-spacing: 0.18em;
  }
  .ix-meta .sep {
    color: var(--color-acid-ink);
  }

  .ix-tagline .jp {
    font-family: var(--font-mincho);
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
  }

  .ix-nodes {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .ix-node {
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1em;
    padding: var(--space-2) var(--space-3);
    pointer-events: auto;
    opacity: 0;
    transition: filter 0.2s ease;
    text-align: center;
    cursor: pointer;
    will-change: transform;
  }
  .ix-node.is-positioned {
    opacity: 1;
  }
  .ix-node:hover {
    filter: drop-shadow(0 0 8px var(--color-acid-dim));
  }
  .ix-node:hover .ix-node-label {
    color: var(--color-acid-ink);
  }

  .ix-node-count {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1;
    color: var(--color-acid);
  }
  .ix-node-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--color-ink);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .ix-node-jp {
    font-family: var(--font-mincho);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--color-ink-muted);
  }

  .ix-strip {
    position: relative;
    z-index: 3;
    grid-row: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    padding: var(--space-2) var(--page-pad);
    font-size: var(--fs-meta);
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
    border-top: 1px solid var(--color-rule);
    background: color-mix(in srgb, var(--color-bg) 60%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .ix-strip a {
    color: var(--color-ink);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .ix-strip a:hover {
    color: var(--color-acid-ink);
  }
  .ix-strip .sep {
    color: var(--color-acid-ink);
  }
  .ix-strip-dot {
    width: 0.4em;
    height: 0.4em;
    border-radius: 50%;
    background: var(--color-acid);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-acid) 25%, transparent);
    animation: strip-pulse 2.6s ease-in-out infinite;
  }
  @keyframes strip-pulse {
    0%, 100% { box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-acid) 25%, transparent); }
    50% { box-shadow: 0 0 0 6px color-mix(in srgb, var(--color-acid) 8%, transparent); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ix-strip-dot { animation: none; }
  }

  .ix-foot {
    position: relative;
    z-index: 3;
    grid-row: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4em;
    padding: var(--space-1) var(--page-pad) var(--space-2);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    color: var(--color-ink-muted);
    background: color-mix(in srgb, var(--color-bg) 60%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .ix-foot .sep {
    color: var(--color-acid-ink);
  }

  @media (max-width: 640px) {
    .ix-node-count { font-size: 1.1rem; }
    .ix-node-label { font-size: 0.5rem; }
    .ix-node-jp { font-size: 0.6rem; }
    .ix-strip {
      font-size: 0.55rem;
      flex-wrap: wrap;
      gap: 0.3em;
    }
  }
</style>
