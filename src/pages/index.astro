---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroCanvas from '~/components/HeroCanvas.astro';
import Logotype from '~/components/Logotype.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { id: '01', label: 'LEYDA-MONO', href: `${base}/novel/`, jp: '小説' },
  { id: '02', label: 'MONTRA-MESA', href: `${base}/gallery/`, jp: '絵' },
  { id: '03', label: 'NOMA-DI MOKURO', href: `${base}/characters/`, jp: '人物' },
  { id: '04', label: 'MONDO-DI NOTA', href: `${base}/mondo/`, jp: '世界注' },
  { id: '05', label: 'LEKSIKO', href: `${base}/lexicon/`, jp: '辞書' },
];

// "Now" strip data — every piece below is computed at build time from the
// content collections. No manual bookkeeping: each deploy re-reads the
// filesystem, picks the freshest dated entries, and updates the stamp.
const [novel, gallery, characters, codex, lexicon, cronika] = await Promise.all([
  getCollection('novel'),
  getCollection('gallery'),
  getCollection('characters'),
  getCollection('codex'),
  getCollection('lexicon'),
  getCollection('cronika'),
]);

const latestChapter = novel
  .slice()
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())[0];
const latestImage = gallery
  .slice()
  .sort((a, b) => b.data.createdAt.getTime() - a.data.createdAt.getTime())[0];
const latestCronika = cronika
  .slice()
  .sort((a, b) => b.data.loggedAt.getTime() - a.data.loggedAt.getTime())[0];

// Pick a "random" lexicon term using a deterministic rotation based on build day
// (so the same page render shows the same term, but it changes daily in CI).
const day = Math.floor(Date.now() / (1000 * 60 * 60 * 24));
const lexPick = lexicon[day % lexicon.length];

const fmt = (d: Date) => d.toISOString().slice(0, 10).replace(/-/g, '.');
const pad = (n: number) => String(n).padStart(2, '0');

// "Last update" pulls from every dated collection so any addition — a chapter,
// an image, or an editor's log entry — bumps the stamp.
const lastUpdateDate = [
  latestChapter?.data.publishedAt,
  latestImage?.data.createdAt,
  latestCronika?.data.loggedAt,
].filter(Boolean).sort((a: any, b: any) => b.getTime() - a.getTime())[0] as Date | undefined;
const lastUpdateStr = lastUpdateDate ? fmt(lastUpdateDate) : '—';

const kindLabel: Record<string, string> = {
  add: '追加',
  fix: '修繕',
  note: '手記',
  release: '公刊',
};

const stats = [
  { k: 'LEYDA', n: novel.length, jp: '章' },
  { k: 'PANA', n: gallery.length, jp: '画' },
  { k: 'NOMA', n: characters.length, jp: '人' },
  { k: 'MONDO', n: codex.length, jp: '注' },
  { k: 'LEKSIKO', n: lexicon.length, jp: '語' },
];
---

<BaseLayout mode="void" showRouteIndex={false}>
  <section class="index-hero">
    <div class="hero-meta mono" data-reveal>
      <span>[00 / MOKURO]</span>
      <span class="sep">·</span>
      <span>VOLA 001</span>
    </div>

    <div class="wordmark-stage" data-reveal>
      <Logotype size="hero" href={`${base}/`} />
    </div>

    <div class="hero-stage" data-reveal>
      <HeroCanvas />
    </div>

    <p class="tagline" data-reveal>
      <span class="jp">電子果汁アーカイブ</span>
      <span class="en mono">pana-di leyda-mono & montra-mesa — norma-tak, manka-kel.</span>
    </p>

    <nav class="index-links" aria-label="Banda">
      <ul>
        {
          links.map((l) => (
            <li>
              <a class="index-link" href={l.href}>
                <span class="n">[{l.id}]</span>
                <span class="l">{l.label}</span>
                <span class="jp">{l.jp}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <section class="now" aria-label="Current" data-reveal>
      <header class="now-head mono">
        <span class="now-label">
          <span class="now-dot" aria-hidden="true"></span>
          <span>NUN · 現</span>
        </span>
        <span class="now-date">{lastUpdateStr}</span>
      </header>

      <div class="now-grid">
        {latestChapter && (
          <a class="now-cell" href={`${base}/novel/${latestChapter.slug}/`}>
            <span class="now-k mono">
              <span class="acid">+</span> LEYDA-MONO · ST.{pad(latestChapter.data.chapterNumber)}
            </span>
            <span class="now-jp">{latestChapter.data.title}</span>
            {latestChapter.data.summary && (
              <span class="now-sum">{latestChapter.data.summary}</span>
            )}
            <span class="now-meta mono meta-dim">
              {fmt(latestChapter.data.publishedAt)}
              {latestChapter.data.series && (
                <>
                  <span class="sep">·</span>
                  <span>{latestChapter.data.series}</span>
                </>
              )}
            </span>
          </a>
        )}

        {latestImage && (
          <a class="now-cell" href={`${base}/gallery/${latestImage.slug}/`}>
            <span class="now-k mono">
              <span class="acid">+</span> MONTRA-MESA
            </span>
            <span class="now-jp">{latestImage.data.title}</span>
            <span class="now-meta mono meta-dim">
              {fmt(latestImage.data.createdAt)}
              <span class="sep">·</span>
              <span>{latestImage.data.medium}</span>
            </span>
          </a>
        )}

        {latestCronika && (
          <a class="now-cell" href={`${base}/cronika/#${latestCronika.slug}`}>
            <span class="now-k mono">
              <span class="acid">·</span> CRONIKA · {kindLabel[latestCronika.data.kind] ?? '手記'}
            </span>
            <span class="now-jp">{latestCronika.data.title}</span>
            <span class="now-meta mono meta-dim">
              {fmt(latestCronika.data.loggedAt)}
              <span class="sep">·</span>
              <span>{latestCronika.data.entryId}</span>
            </span>
          </a>
        )}

        {lexPick && (
          <a class="now-cell" href={`${base}/lexicon/#${lexPick.slug}`}>
            <span class="now-k mono">
              <span class="acid">∞</span> LEKSIKO · DU JORNA
            </span>
            <span class="now-jp word-pick">{lexPick.data.word}</span>
            <span class="now-sum">{lexPick.data.gloss}</span>
            {lexPick.data.definition && (
              <span class="now-meta mono meta-dim">{lexPick.data.definition.slice(0, 60)}…</span>
            )}
          </a>
        )}
      </div>

      <ul class="now-stats mono" aria-label="Counts">
        {stats.map((s) => (
          <li class="stat">
            <span class="stat-n" data-count-up>{pad(s.n)}</span>
            <span class="stat-k">{s.k}</span>
            <span class="stat-jp">{s.jp}</span>
          </li>
        ))}
      </ul>
    </section>
  </section>
</BaseLayout>

<script>
  import '~/scripts/count-up';
</script>

<style>
  .index-hero {
    max-width: var(--max-page);
    margin-inline: auto;
    display: grid;
    /* Compress vertical rhythm so the first fold (meta → wordmark → chalice →
       tagline) fits within a retina viewport height. The links / NOW strip
       below may fall beyond the fold and that's intentional. */
    gap: clamp(1rem, 2.4vh, 3rem);
    padding-block: clamp(1.25rem, 3.5vh, 4rem);
  }
  .hero-meta {
    display: flex;
    gap: 0.5em;
    justify-content: center;
    color: var(--color-ink-muted);
  }
  .hero-meta .sep {
    color: var(--color-acid);
  }
  .wordmark-stage {
    display: grid;
    place-items: center;
    text-align: center;
  }
  .hero-stage {
    display: grid;
    place-items: center;
    position: relative;
  }
  .hero-stage::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 30%;
    background: linear-gradient(to top, var(--color-bg), transparent);
    pointer-events: none;
  }
  .tagline {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
    text-align: center;
  }
  .tagline .jp {
    font-family: var(--font-mincho);
    font-size: 1.25rem;
    letter-spacing: 0.08em;
    color: var(--color-ink);
  }
  .tagline .en {
    color: var(--color-ink-muted);
    font-size: var(--fs-meta);
  }
  .index-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-rule);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }
  .index-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-8) var(--space-4);
    background: var(--color-bg);
    text-align: center;
    transition: background var(--dur-mid) var(--ease-out);
  }
  .index-link:hover,
  .index-link:focus-visible {
    background: color-mix(in srgb, var(--color-bg) 88%, var(--color-acid) 12%);
  }
  .index-link .n {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    color: var(--color-acid);
  }
  .index-link .l {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    color: var(--color-ink);
  }
  .index-link .jp {
    font-family: var(--font-mincho);
    font-size: 0.875rem;
    letter-spacing: 0.2em;
    color: var(--color-ink-muted);
  }

  .index-links ul {
    grid-template-columns: repeat(5, 1fr);
  }

  @media (max-width: 64rem) {
    .index-links ul {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 48rem) {
    .index-links ul {
      grid-template-columns: 1fr;
    }
    .index-link {
      padding: var(--space-6) var(--space-4);
    }
  }

  /* ============================================================
     NOW · 現 — activity strip
     ============================================================ */
  .now {
    display: grid;
    gap: var(--space-6);
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-6);
  }
  .now-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    font-size: var(--fs-meta);
    letter-spacing: 0.18em;
    color: var(--color-ink-muted);
  }
  .now-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    color: var(--color-ink);
  }
  .now-dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--color-acid);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-acid) 25%, transparent);
    animation: now-pulse 2.6s ease-in-out infinite;
  }
  @keyframes now-pulse {
    0%, 100% {
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-acid) 25%, transparent);
    }
    50% {
      box-shadow: 0 0 0 8px color-mix(in srgb, var(--color-acid) 8%, transparent);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .now-dot {
      animation: none;
    }
  }

  .now-grid {
    display: grid;
    /* auto-fit so the strip gracefully adapts to 3 or 4 cells (or more,
       if future cells are added). Min cell width keeps text readable. */
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1px;
    background: var(--color-rule);
    border: 1px solid var(--color-rule);
  }
  @media (max-width: 48rem) {
    .now-grid {
      grid-template-columns: 1fr;
    }
  }
  .now-cell {
    display: grid;
    gap: var(--space-2);
    padding: var(--space-5) var(--space-4);
    background: var(--color-bg);
    transition: background var(--dur-mid) var(--ease-out);
  }
  .now-cell:hover,
  .now-cell:focus-visible {
    background: color-mix(in srgb, var(--color-bg) 88%, var(--color-acid) 12%);
  }
  .now-k {
    font-size: var(--fs-meta);
    letter-spacing: 0.14em;
    color: var(--color-ink-muted);
    display: inline-flex;
    gap: 0.4em;
  }
  .now-k .acid {
    color: var(--color-acid);
  }
  .now-jp {
    font-family: var(--font-mincho);
    font-size: 1.125rem;
    letter-spacing: 0.03em;
    color: var(--color-ink);
  }
  .now-jp.word-pick {
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    font-size: 1rem;
  }
  .now-sum {
    font-family: var(--font-mincho);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-ink-muted);
  }
  .now-meta {
    font-size: var(--fs-meta);
    letter-spacing: 0.1em;
    color: var(--color-ink-muted);
  }
  .now-meta .sep {
    color: var(--color-acid);
    margin-inline: 0.4em;
  }

  .now-stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    background: var(--color-rule);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
    align-items: center;
    padding: var(--space-4) var(--space-2);
    background: var(--color-bg);
    text-align: center;
  }
  .stat-n {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }
  .stat-k {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    color: var(--color-acid);
  }
  .stat-jp {
    font-family: var(--font-mincho);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--color-ink-muted);
  }
  @media (max-width: 48rem) {
    .now-stats {
      grid-template-columns: repeat(5, 1fr);
    }
  }
</style>
