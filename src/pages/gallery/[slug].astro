---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const all = await getCollection('gallery');
  const sorted = all.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((entry, i) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
      index: i + 1,
      total: sorted.length,
    },
  }));
}

interface Props {
  entry: CollectionEntry<'gallery'>;
  prev: CollectionEntry<'gallery'> | null;
  next: CollectionEntry<'gallery'> | null;
  index: number;
  total: number;
}

const { entry, prev, next, index, total } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pad = (n: number) => String(n).padStart(4, '0');
const date = entry.data.createdAt.toISOString().slice(0, 10).replace(/-/g, '.');
const { Content } = await entry.render();
const prevHref = prev ? `${base}/gallery/${prev.slug}/` : '';
const nextHref = next ? `${base}/gallery/${next.slug}/` : '';
---

<BaseLayout title={`${entry.data.title} / GALLERY`} mode="void" showRouteIndex={false}>
  <article class="detail page-column">
    <header class="detail-head">
      <p class="mono">[02 / GALLERY] · V.{pad(index)} / {pad(total)}</p>
    </header>

    <div class="main">
      <div class="image-frame">
        <Image
          src={entry.data.image}
          alt={entry.data.alt}
          class="image"
          widths={[960, 1280, 1600]}
          sizes="(min-width: 72rem) 74vw, 96vw"
        />
      </div>

      <div class="caption">
        <h1 class="title">{entry.data.title}</h1>
        <dl class="mono">
          <div><dt>DATE</dt><dd>{date}</dd></div>
          <div><dt>MEDIUM</dt><dd>{entry.data.medium}</dd></div>
          {entry.data.dimensions && (<div><dt>DIM</dt><dd>{entry.data.dimensions}</dd></div>)}
        </dl>
        <div class="note">
          <Content />
        </div>
      </div>
    </div>

    <nav class="pager" aria-label="Image navigation" data-prev={prevHref} data-next={nextHref}>
      <div class="slot">
        {
          prev ? (
            <a class="acid-link mono" href={prevHref}>
              <span class="acid">[←]</span> V.{pad(index - 1)}
            </a>
          ) : (
            <span class="mono meta-dim">[—]</span>
          )
        }
      </div>
      <div class="slot center">
        <a class="acid-link mono" href={`${base}/gallery/`}>INDEX</a>
      </div>
      <div class="slot right">
        {
          next ? (
            <a class="acid-link mono" href={nextHref}>
              V.{pad(index + 1)} <span class="acid">[→]</span>
            </a>
          ) : (
            <span class="mono meta-dim">[—]</span>
          )
        }
      </div>
    </nav>
  </article>
</BaseLayout>

<script>
  const pager = document.querySelector('.pager');
  const prevHref = pager?.getAttribute('data-prev') ?? '';
  const nextHref = pager?.getAttribute('data-next') ?? '';

  document.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement | null;
    if (target && ['INPUT', 'TEXTAREA', 'SELECT'].includes(target.tagName)) return;
    if (e.metaKey || e.ctrlKey || e.altKey || e.shiftKey) return;
    if (e.key === 'ArrowLeft' && prevHref) location.assign(prevHref);
    if (e.key === 'ArrowRight' && nextHref) location.assign(nextHref);
  });
</script>

<style>
  .detail {
    display: grid;
    gap: var(--space-8);
  }
  .main {
    display: grid;
    gap: var(--space-8);
    align-items: start;
  }
  @media (min-width: 72rem) {
    .main {
      grid-template-columns: minmax(0, 1fr) 18rem;
      gap: var(--space-12);
    }
  }
  .image-frame {
    border: 1px solid var(--color-rule);
    background: #050504;
    overflow: hidden;
    max-width: 1200px;
    margin-inline: auto;
    width: 100%;
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.16);
  }
  .image {
    width: 100%;
    height: auto;
    display: block;
  }
  .caption {
    display: grid;
    gap: var(--space-4);
    width: 100%;
    align-content: start;
  }
  @media (min-width: 72rem) {
    .caption {
      position: sticky;
      top: calc(var(--space-section) + var(--space-2));
      align-self: start;
    }
  }
  .title {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    letter-spacing: 0.1em;
    font-weight: 500;
    color: var(--color-ink);
  }
  dl {
    display: grid;
    gap: var(--space-2);
  }
  dl > div {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-3);
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-2);
  }
  dt {
    color: var(--color-ink-muted);
  }
  .note {
    font-family: var(--font-mincho);
    font-size: var(--fs-body);
    line-height: var(--lh-reading);
    letter-spacing: 0.04em;
    color: var(--color-ink);
  }
  .pager {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: baseline;
    gap: var(--space-4);
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-4);
  }
  .slot.right {
    text-align: right;
  }
  .slot.center {
    text-align: center;
  }
  .acid {
    color: var(--color-acid);
  }
</style>
