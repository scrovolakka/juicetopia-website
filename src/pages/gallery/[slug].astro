---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const all = await getCollection('gallery');
  const sorted = all.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((entry, i) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
      index: i + 1,
      total: sorted.length,
    },
  }));
}

interface Props {
  entry: CollectionEntry<'gallery'>;
  prev: CollectionEntry<'gallery'> | null;
  next: CollectionEntry<'gallery'> | null;
  index: number;
  total: number;
}

const { entry, prev, next, index, total } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pad = (n: number) => String(n).padStart(4, '0');
const date = entry.data.createdAt.toISOString().slice(0, 10).replace(/-/g, '.');
const { Content } = await entry.render();

// Orientation-based sizing: landscape fills the page column, portrait and
// square keep the previous 960 px cap. astro:assets gives us the intrinsic
// dimensions at build time.
const imgAspect = entry.data.image.width / entry.data.image.height;
const orientation =
  imgAspect > 1.05 ? 'landscape' : imgAspect < 0.95 ? 'portrait' : 'square';
---

<BaseLayout title={`${entry.data.title} / MONTRA-MESA`} mode="void" showRouteIndex={false}>
  <article class="detail page-column">
    <header class="detail-head">
      <p class="mono">[02 / MONTRA-MESA] · V.{pad(index)} / {pad(total)}</p>
    </header>

    <div class="image-frame" data-orientation={orientation}>
      <Image
        src={entry.data.image}
        alt={entry.data.alt}
        class="image"
        widths={[640, 960, 1280, 1600]}
        sizes={
          orientation === 'landscape'
            ? '(min-width: 72rem) 1152px, 95vw'
            : '(min-width: 72rem) 960px, 90vw'
        }
      />
    </div>

    <div class="caption">
      <h1 class="title">{entry.data.title}</h1>
      <dl class="mono">
        <div><dt>DATA</dt><dd>{date}</dd></div>
        <div><dt>MONO</dt><dd>{entry.data.medium}</dd></div>
        {entry.data.dimensions && (<div><dt>METRA-FAKTA</dt><dd>{entry.data.dimensions}</dd></div>)}
      </dl>
      <div class="note">
        <Content />
      </div>
    </div>

    <nav class="pager" aria-label="Mira-di mokuro">
      <div class="slot">
        {
          prev ? (
            <a class="acid-link mono" href={`${base}/gallery/${prev.slug}/`}>
              <span class="acid">[←]</span> V.{pad(index - 1)}
            </a>
          ) : (
            <span class="mono meta-dim">[—]</span>
          )
        }
      </div>
      <div class="slot center">
        <a class="acid-link mono" href={`${base}/gallery/`}>MOKURO</a>
      </div>
      <div class="slot right">
        {
          next ? (
            <a class="acid-link mono" href={`${base}/gallery/${next.slug}/`}>
              V.{pad(index + 1)} <span class="acid">[→]</span>
            </a>
          ) : (
            <span class="mono meta-dim">[—]</span>
          )
        }
      </div>
    </nav>
  </article>
</BaseLayout>

<style>
  .detail {
    display: grid;
    gap: var(--space-8);
  }
  .image-frame {
    border: 1px solid var(--color-rule);
    background: #050504;
    overflow: hidden;
    margin-inline: auto;
    width: 100%;
  }
  /* Landscape images breathe the full page-column (72rem, via .detail). */
  .image-frame[data-orientation='landscape'] {
    max-width: 100%;
  }
  /* Portrait / square stay at the previous 960 px cap so tall images don't
     dominate the viewport. */
  .image-frame[data-orientation='portrait'],
  .image-frame[data-orientation='square'] {
    max-width: 960px;
  }
  .image {
    width: 100%;
    height: auto;
    display: block;
  }
  .caption {
    max-width: var(--max-reading);
    margin-inline: auto;
    display: grid;
    gap: var(--space-4);
    width: 100%;
  }
  .title {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    letter-spacing: 0.1em;
    font-weight: 500;
    color: var(--color-ink);
  }
  dl {
    display: grid;
    gap: var(--space-2);
  }
  dl > div {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-3);
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-2);
  }
  dt {
    color: var(--color-ink-muted);
  }
  .note {
    font-family: var(--font-mincho);
    font-size: var(--fs-body);
    line-height: var(--lh-reading);
    letter-spacing: 0.04em;
    color: var(--color-ink);
  }
  .pager {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: baseline;
    gap: var(--space-4);
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-4);
  }
  .slot.right {
    text-align: right;
  }
  .slot.center {
    text-align: center;
  }
  .acid {
    color: var(--color-acid-ink);
  }
</style>
