---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('characters');
const chars = [...all].sort((a, b) => a.data.order - b.data.order);
const pad = (n: number) => String(n).padStart(2, '0');

// Group by faction — the list is organised in sections so clans / camps read
// as distinct columns of the archive.
type Entry = CollectionEntry<'characters'>;
const byFaction = new Map<string, Entry[]>();
for (const c of chars) {
  const k = c.data.faction || 'その他';
  if (!byFaction.has(k)) byFaction.set(k, []);
  byFaction.get(k)!.push(c);
}

// Canonical ordering of factions for the index. Any unknown faction falls
// through to the end in insertion order.
const FACTION_ORDER = [
  '主人公',
  '王のフルーツ',
  '導管民',
  '緑の一族',
  'ドマロンの道具たち',
  'ミューズ',
  '大坂',
  '修繕班',
  'くまちゃん読書会',
  '脚注の王',
  '異形',
  'その他',
];

const FACTION_LABELS: Record<string, { en: string; jp: string }> = {
  '主人公': { en: 'PROTAGONISTS', jp: '主人公' },
  '王のフルーツ': { en: 'I SEI SPREMUTI', jp: '王のフルーツ' },
  '導管民': { en: 'CONDUCTA', jp: '導管民' },
  '緑の一族': { en: 'VERD-LINIA', jp: '緑の一族' },
  'ドマロンの道具たち': { en: 'DOMARON-KE', jp: 'ドマロンの道具たち' },
  'ミューズ': { en: 'MUSA', jp: 'ミューズ' },
  '大坂': { en: 'OSAKA-SHU', jp: '大坂' },
  '修繕班': { en: 'REPARA', jp: '修繕班' },
  'くまちゃん読書会': { en: 'LEKTO-URSA', jp: 'くまちゃん読書会' },
  '脚注の王': { en: 'NOTA-DI DOL', jp: '脚注の王' },
  '異形': { en: 'ALIENA', jp: '異形' },
  'その他': { en: 'ALTRO', jp: 'その他' },
};

const knownOrder = new Set(FACTION_ORDER);
const sections = [
  ...FACTION_ORDER.filter((k) => byFaction.has(k)),
  ...[...byFaction.keys()].filter((k) => !knownOrder.has(k)),
].map((k) => ({
  key: k,
  meta: FACTION_LABELS[k] ?? { en: k.toUpperCase(), jp: k },
  items: byFaction.get(k)!,
}));
---

<BaseLayout title="NOMA-DI MOKURO" description="juicetopia — 登場人物 / dramatis personae.">
  <section class="characters page-column flow-16">
    <header class="flow" data-reveal>
      <h1 class="section-title">
        NOMA-DI MOKURO<br />
        <span class="jp">登場人物</span>
      </h1>
      <p class="mono">NOMA-DI PANA · {pad(chars.length)} FAKTA · {pad(sections.length)} BANDA</p>
    </header>

    <div class="rule"></div>

    <p class="lede" data-reveal>
      名は、目録されることで輪郭をもつ。目録から外れた名も想定されるが、この目録には載らない。
      各項は詳細へ続く扉を持つ。扉は、名前を選んだときに開く。
    </p>

    <div class="rule"></div>

    {
      sections.map((sec) => (
        <article class="faction flow-8" data-reveal>
          <header class="sec-head">
            <h2 class="sec-title">
              {sec.meta.en}
              <span class="sec-sub mono">{sec.meta.jp}</span>
            </h2>
            <span class="sec-count mono meta-dim">{pad(sec.items.length)} FAKTA</span>
          </header>

          <ul class="card-grid" data-reveal-stagger="30">
            {sec.items.map((c) => {
              const href = `${base}/characters/${c.slug}/`;
              return (
                <li class="card" id={c.data.charId} data-reveal>
                  <a class="card-link" href={href}>
                    <div class="portrait" aria-hidden={!c.data.portrait}>
                      {c.data.portrait ? (
                        <Image
                          src={c.data.portrait}
                          alt={c.data.name}
                          widths={[200, 400]}
                          sizes="(min-width: 48rem) 200px, 40vw"
                        />
                      ) : (
                        <span class="portrait-placeholder mono">{c.data.charId}</span>
                      )}
                    </div>
                    <div class="meta">
                      <span class="card-id mono">
                        <span class="acid">{c.data.charId}</span>
                        {c.data.era && (
                          <>
                            <span class="sep meta-dim">·</span>
                            <span class="meta-dim">{c.data.era}</span>
                          </>
                        )}
                      </span>
                      <h3 class="card-name">
                        <span class="jp-name">{c.data.name}</span>
                        {c.data.reading && (
                          <span class="reading mono">{c.data.reading}</span>
                        )}
                      </h3>
                      {c.data.role && <p class="role mono">{c.data.role}</p>}
                      {c.data.tagline && <p class="tagline">{c.data.tagline}</p>}
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        </article>
      ))
    }
  </section>
</BaseLayout>

<style>
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.95;
  }
  .section-title .jp {
    display: block;
    font-family: var(--font-mincho);
    font-size: 0.32em;
    letter-spacing: 0.25em;
    color: var(--color-ink-muted);
    margin-top: var(--space-3);
  }
  .lede {
    max-width: var(--max-reading);
    font-family: var(--font-mincho);
    font-size: var(--fs-reading);
    line-height: var(--lh-reading);
    color: var(--color-ink-muted);
  }
  .faction + .faction {
    margin-top: var(--space-10);
  }
  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-rule);
  }
  .sec-title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    font-weight: 400;
    letter-spacing: 0.3em;
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-acid-dim);
  }
  .sec-sub {
    font-family: var(--font-mincho);
    font-size: 0.72em;
    letter-spacing: 0.2em;
    color: var(--color-ink-muted);
  }
  .sec-count {
    font-size: var(--fs-mono-sm);
    letter-spacing: 0.12em;
  }

  .card-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: var(--space-6) var(--space-4);
  }
  .card {
    scroll-margin-top: 90px;
  }
  .card:target .portrait {
    border-color: var(--color-acid);
  }
  .card-link {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-3);
    border: 1px solid transparent;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }
  .card-link:hover,
  .card-link:focus-visible {
    border-color: var(--color-rule);
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-acid) 8%);
  }
  .portrait {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid var(--color-rule);
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-ink) 8%);
    transition: border-color var(--dur-mid) var(--ease-out);
    display: grid;
    place-items: center;
  }
  .card-link:hover .portrait,
  .card-link:focus-visible .portrait {
    border-color: var(--color-acid);
  }
  .portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .portrait-placeholder {
    font-size: 1rem;
    letter-spacing: 0.2em;
    color: var(--color-ink-muted);
    padding: 0.5em 0.75em;
    border: 1px solid var(--color-rule);
  }
  .meta {
    display: grid;
    gap: var(--space-1);
  }
  .card-id {
    display: inline-flex;
    gap: 0.4em;
    font-size: var(--fs-meta);
    letter-spacing: 0.14em;
  }
  .sep {
    padding: 0 0.1em;
  }
  .card-name {
    display: grid;
    gap: 0.1em;
    font-weight: 500;
    margin: 0;
  }
  .jp-name {
    font-family: var(--font-mincho);
    font-size: 1.15rem;
    letter-spacing: 0.04em;
    color: var(--color-ink);
  }
  .reading {
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
    font-style: normal;
    text-transform: none;
  }
  .role {
    font-size: var(--fs-meta);
    letter-spacing: 0.1em;
    color: var(--color-acid);
    text-transform: none;
    margin: 0;
  }
  .tagline {
    font-family: var(--font-mincho);
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--color-ink-muted);
    margin: 0;
  }
</style>
