---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('characters');
const chars = await Promise.all(
  all
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (c) => {
      const rendered = await c.render();
      const mondoRefs = await Promise.all(
        (c.data.mondoRefs ?? []).map((slug) => getEntry('codex', slug).catch(() => null)),
      ).then((arr) => arr.filter(Boolean));
      const leksikoRefs = await Promise.all(
        (c.data.leksikoRefs ?? []).map((slug) =>
          getEntry('lexicon', slug).catch(() => null),
        ),
      ).then((arr) => arr.filter(Boolean));
      return { entry: c, rendered, mondoRefs, leksikoRefs };
    }),
);
const pad = (n: number) => String(n).padStart(2, '0');
---

<BaseLayout title="NOMA-DI MOKURO" description="juicetopia noma-di pana.">
  <section class="characters page-column flow-16">
    <header class="flow">
      <h1 class="section-title" data-reveal>
        NOMA-DI MOKURO<br />
        <span class="jp">登場人物</span>
      </h1>
      <p class="mono">NOMA-DI PANA · {pad(chars.length)} FAKTA</p>
    </header>

    <div class="rule"></div>

    <ul class="char-list">
      {
        chars.map(({ entry, rendered, mondoRefs, leksikoRefs }) => {
          const { Content } = rendered;
          return (
            <li class="char" id={entry.data.charId} data-reveal>
              <div class="portrait">
                <Image src={entry.data.portrait} alt={entry.data.name} widths={[240, 480]} sizes="(min-width: 48rem) 240px, 50vw" />
              </div>
              <div class="info">
                <p class="mono">
                  <span class="acid">[{entry.data.charId}]</span>
                </p>
                <h2 class="name">
                  <span class="jp-name">{entry.data.name}</span>
                  {entry.data.reading && <span class="reading mono">{entry.data.reading}</span>}
                </h2>
                <div class="bio">
                  <Content />
                </div>
                {(mondoRefs.length > 0 || leksikoRefs.length > 0) && (
                  <div class="char-refs mono">
                    {mondoRefs.length > 0 && (
                      <div class="refs-row">
                        <span class="refs-label meta-dim">MONDO</span>
                        {mondoRefs.map((m: any, i: number) => (
                          <>
                            {i > 0 && <span class="refs-sep meta-dim">·</span>}
                            <a class="ref-a" href={`${base}/mondo/${m.slug}/`}>
                              {m.data.label}
                            </a>
                          </>
                        ))}
                      </div>
                    )}
                    {leksikoRefs.length > 0 && (
                      <div class="refs-row">
                        <span class="refs-label meta-dim">LEKSIKO</span>
                        {leksikoRefs.map((l: any, i: number) => (
                          <>
                            {i > 0 && <span class="refs-sep meta-dim">·</span>}
                            <a class="ref-a" href={`${base}/lexicon/#${l.slug}`}>
                              {l.data.word}
                            </a>
                          </>
                        ))}
                      </div>
                    )}
                  </div>
                )}
              </div>
            </li>
          );
        })
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.95;
  }
  .section-title .jp {
    display: block;
    font-family: var(--font-mincho);
    font-size: 0.32em;
    letter-spacing: 0.25em;
    color: var(--color-ink-muted);
    margin-top: var(--space-3);
  }
  .char-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-12);
  }
  .char {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: var(--space-8);
    align-items: start;
    border-top: none;
    padding-top: var(--space-8);
    position: relative;
  }
  .char + .char::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-acid-dim), transparent);
  }
  .char:first-child {
    padding-top: 0;
  }
  .portrait {
    width: 320px;
    height: 320px;
    overflow: hidden;
    border: 1px solid var(--color-rule);
    background: var(--color-bg);
    transition: border-color var(--dur-mid) var(--ease-out);
  }
  .char:hover .portrait {
    border-color: var(--color-acid);
  }
  .portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .info {
    display: grid;
    gap: var(--space-3);
  }
  .name {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
    font-weight: 500;
  }
  .jp-name {
    font-family: var(--font-mincho);
    font-size: 1.75rem;
    letter-spacing: 0.08em;
    color: var(--color-ink);
  }
  .reading {
    color: var(--color-ink-muted);
  }
  .bio {
    font-family: var(--font-mincho);
    font-size: var(--fs-reading);
    line-height: var(--lh-reading);
    letter-spacing: 0.04em;
    max-width: 40ch;
  }
  .char:target {
    padding-inline-start: var(--space-4);
    border-inline-start: 2px solid var(--color-acid);
  }
  .char-refs {
    display: grid;
    gap: var(--space-2);
    padding-top: var(--space-4);
    margin-top: var(--space-2);
    border-top: 1px solid var(--color-rule);
    font-size: var(--fs-meta);
    letter-spacing: 0.1em;
  }
  .refs-row {
    display: flex;
    gap: 0.6em;
    flex-wrap: wrap;
    align-items: baseline;
  }
  .refs-label {
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    width: 4rem;
  }
  .refs-sep {
    color: var(--color-ink-muted);
  }
  .ref-a {
    color: var(--color-ink);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }
  .ref-a:hover,
  .ref-a:focus-visible {
    border-bottom-color: var(--color-acid);
    color: var(--color-acid);
  }

  @media (max-width: 48rem) {
    .char {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .portrait {
      width: 100%;
      max-width: 280px;
      height: auto;
      aspect-ratio: 1;
    }
  }
</style>
