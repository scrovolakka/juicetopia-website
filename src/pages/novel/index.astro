---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('novel');
const chapters = all.sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
const pad = (n: number) => String(n).padStart(2, '0');
const total = chapters.length;
---

<BaseLayout title="NOVEL" description="juicetopia novel index.">
  <section class="novel-index page-column flow-16">
    <header class="flow">
      <h1 class="section-title">
        NOVEL<br />
        <span class="jp">小説</span>
      </h1>
      <p class="mono">INDEX · {pad(total)} CHAPTER{total === 1 ? '' : 'S'}</p>
    </header>

    <div class="rule"></div>

    <ol class="ch-list">
      {
        chapters.map((c) => {
          const date = c.data.publishedAt.toISOString().slice(0, 10).replace(/-/g, '.');
          const href = `${base}/novel/${c.slug}/`;
          return (
            <li class="ch">
              <a class="ch-link" href={href}>
                <span class="col-num mono">CH.{pad(c.data.chapterNumber)}</span>
                <span class="col-title">{c.data.title}</span>
                <span class="col-date mono meta-dim">{date}</span>
              </a>
            </li>
          );
        })
      }
    </ol>
  </section>
</BaseLayout>

<style>
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.95;
  }
  .section-title .jp {
    display: block;
    font-family: var(--font-mincho);
    font-size: 0.32em;
    letter-spacing: 0.25em;
    color: var(--color-ink-muted);
    margin-top: var(--space-3);
  }
  .ch-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-rule);
  }
  .ch {
    border-bottom: 1px solid var(--color-rule);
  }
  .ch-link {
    display: grid;
    grid-template-columns: 4rem 1fr auto;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-6) 0;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .ch-link:hover,
  .ch-link:focus-visible {
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-acid) 8%);
  }
  .col-num {
    color: var(--color-acid);
  }
  .col-title {
    font-family: var(--font-mincho);
    font-size: var(--fs-reading);
    letter-spacing: 0.04em;
    color: var(--color-ink);
  }
  @media (max-width: 40rem) {
    .ch-link {
      grid-template-columns: 4rem 1fr;
      grid-template-rows: auto auto;
      row-gap: var(--space-1);
    }
    .col-date {
      grid-column: 2;
    }
  }
</style>
