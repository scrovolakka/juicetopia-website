---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('novel');
const sortedAll = [...all].sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
const pad = (n: number) => String(n).padStart(2, '0');
const total = sortedAll.length;

type Entry = CollectionEntry<'novel'>;
const groups = new Map<string, Entry[]>();
for (const e of sortedAll) {
  const key = e.data.series ?? '';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(e);
}
for (const arr of groups.values()) {
  arr.sort(
    (a, b) =>
      (a.data.seriesOrder ?? a.data.chapterNumber) -
      (b.data.seriesOrder ?? b.data.chapterNumber),
  );
}

// Display order: main line → serialised cycles → shorts → long-form archive.
const seriesOrderList = ['', '泥の断章', '脚注の王', '短編', '長編'];
const labelMap: Record<string, { label: string; sub: string }> = {
  '': { label: 'RIGOLA UN-MA', sub: '本編' },
  '泥の断章': { label: 'DORO-DI BANDA', sub: '泥の断章' },
  '脚注の王': { label: 'NOTA-DI DOL-SHA', sub: '脚注の王' },
  '短編': { label: 'MONO KORTA', sub: '短編' },
  '長編': { label: 'MONO LONGA', sub: 'アーカイブ' },
};
const sections = seriesOrderList
  .filter((k) => groups.has(k))
  .map((k) => ({
    key: k,
    meta: labelMap[k] ?? { label: k.toUpperCase(), sub: k },
    items: groups.get(k)!,
  }));
---

<BaseLayout title="LEYDA-MONO" description="juicetopia leyda-mono mokuro.">
  <section class="novel-index page-column flow-16">
    <header class="flow">
      <h1 class="section-title">
        LEYDA-MONO<br />
        <span class="jp">小説</span>
      </h1>
      <p class="mono">MOKURO · {pad(total)} STRATA · {sections.length} BANDA</p>
    </header>

    <div class="rule"></div>

    {
      sections.map((sec) => (
        <article class="section-block flow-8">
          <header class="sec-head">
            <h2 class="sec-title">
              {sec.meta.label}
              <span class="sec-sub mono">{sec.meta.sub}</span>
            </h2>
            <span class="sec-count mono meta-dim">{pad(sec.items.length)} FAKTA</span>
          </header>
          <ol class="ch-list">
            {sec.items.map((c) => {
              const date = c.data.publishedAt.toISOString().slice(0, 10).replace(/-/g, '.');
              const href = `${base}/novel/${c.slug}/`;
              return (
                <li class="ch">
                  <a class="ch-link" href={href}>
                    <span class="col-num mono">ST.{pad(c.data.chapterNumber)}</span>
                    <span class="col-title">{c.data.title}</span>
                    <span class="col-date mono meta-dim">{date}</span>
                  </a>
                </li>
              );
            })}
          </ol>
        </article>
      ))
    }
  </section>
</BaseLayout>

<style>
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.95;
  }
  .section-title .jp {
    display: block;
    font-family: var(--font-mincho);
    font-size: 0.32em;
    letter-spacing: 0.25em;
    color: var(--color-ink-muted);
    margin-top: var(--space-3);
  }
  .section-block {
    padding-top: var(--space-8);
  }
  .section-block + .section-block {
    margin-top: var(--space-10);
  }
  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-rule);
  }
  .sec-title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    font-weight: 400;
    letter-spacing: 0.18em;
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .sec-sub {
    font-family: var(--font-mincho);
    font-size: 0.72em;
    letter-spacing: 0.2em;
    color: var(--color-ink-muted);
  }
  .sec-count {
    font-size: var(--fs-mono-sm);
    letter-spacing: 0.12em;
  }
  .ch-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .ch {
    border-bottom: 1px solid var(--color-rule);
  }
  .ch-link {
    display: grid;
    grid-template-columns: 4rem 1fr auto;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .ch-link:hover,
  .ch-link:focus-visible {
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-acid) 8%);
  }
  .col-num {
    color: var(--color-acid);
  }
  .col-title {
    font-family: var(--font-mincho);
    font-size: var(--fs-reading);
    letter-spacing: 0.04em;
    color: var(--color-ink);
  }
  @media (max-width: 40rem) {
    .ch-link {
      grid-template-columns: 4rem 1fr;
      grid-template-rows: auto auto;
      row-gap: var(--space-1);
    }
    .col-date {
      grid-column: 2;
    }
  }
</style>
