---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Pull the three most recent editor's log entries for the CRONIKA digest.
// Full history stays on /cronika/; this page shows a compact summary so the
// reader can see recent meta-commentary at a glance.
const allCronika = await getCollection('cronika');
const recentLog = allCronika
  .slice()
  .sort((a, b) => b.data.loggedAt.getTime() - a.data.loggedAt.getTime())
  .slice(0, 3);

const fmt = (d: Date) => d.toISOString().slice(0, 10).replace(/-/g, '.');
const kindLabel: Record<string, { en: string; jp: string }> = {
  add: { en: 'ADD', jp: '追加' },
  fix: { en: 'FIX', jp: '修繕' },
  note: { en: 'NOTE', jp: '手記' },
  release: { en: 'REL', jp: '公刊' },
};
---

<BaseLayout title="NOTA" description="juicetopia — nota-di pana.">
  <article class="about page-column">
    <header class="about-head" data-reveal>
      <h1 class="about-title">NOTA<br /><span class="jp">Juicetpiaについて</span></h1>
      <p class="mono">[04 / NOTA] · NOTA-DI NORMA · A.02</p>
    </header>

    <div class="rule"></div>

    <section class="about-body flow-8" data-reveal>
      <p>
        juicetopia は、小説とビジュアルを公開するための小さなアーカイブです。網羅的ではなく、あえて選び取った断片だけを置いています。
      </p>
      <p>
        目次は三つ。<a class="acid-link" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/novel/`}>小説</a> は読み物の欄。<a class="acid-link" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/gallery/`}>ギャラリー</a>
         は画像の欄。<a class="acid-link" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/characters/`}
          >キャラクター</a
        > は登場人物の欄です。
      </p>
      <p>
        サイト全体に走る走査線とグレインは、古い映像機器の記録であることを示すためのものです。電源は切っていません。
      </p>
      <p>
        世界の固有名詞と語彙は、別項の <a class="acid-link" href={`${base}/mondo/`}>MONDO-DI NOTA</a> と <a class="acid-link" href={`${base}/lexicon/`}>LEKSIKO</a> に置いています。通読の必要はありません。本文を読むためにも、注釈を読むためにも。
      </p>
    </section>

    <div class="rule"></div>

    <section class="about-log flow" data-reveal>
      <h2>
        <a class="codex-jump" href={`${base}/cronika/`}>CRONIKA</a>
        <span class="jp-sub">—— 編集後記の最新 3 件（→ <a class="codex-jump" href={`${base}/cronika/`}>全履歴</a>）</span>
      </h2>
      <ul class="log-digest">
        {recentLog.map((e) => {
          const k = kindLabel[e.data.kind] ?? kindLabel.note;
          return (
            <li>
              <a class="log-link" href={`${base}/cronika/#${e.slug}`}>
                <span class="log-meta mono">
                  <span class="acid">{e.data.entryId}</span>
                  <span class={`log-kind kind-${e.data.kind}`}>
                    <span class="kind-en">{k.en}</span>
                    <span class="kind-jp">{k.jp}</span>
                  </span>
                  <span class="log-date meta-dim">{fmt(e.data.loggedAt)}</span>
                </span>
                <span class="log-title">{e.data.title}</span>
              </a>
            </li>
          );
        })}
      </ul>
      <p class="log-more mono">
        <a class="codex-jump" href={`${base}/cronika/`}>→ 全編集後記は CRONIKA へ</a>
      </p>
    </section>

    <div class="rule"></div>

    <section class="about-credits flow" data-reveal>
      <h2>GRATI-DI NOTA</h2>
      <dl class="mono">
        <div><dt>FORNA</dt><dd>Astro · Three.js</dd></div>
        <div><dt>STAMPA</dt><dd>DiscoDeco · JetBrains Mono · Shippori Mincho B1 · Noto Sans JP</dd></div>
        <div><dt>ACCENT</dt><dd>#D8FF3A <span class="meta-dim">— SOLA-ACID</span></dd></div>
        <div><dt>PANA</dt><dd>JCT · A.02</dd></div>
      </dl>
    </section>
  </article>
</BaseLayout>

<style>
  .about {
    display: grid;
    gap: var(--space-8);
  }
  .about-head {
    display: grid;
    gap: var(--space-4);
  }
  .about-title {
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: var(--ls-display);
    line-height: 0.95;
  }
  .about-title .jp {
    display: block;
    font-family: var(--font-mincho);
    font-size: 0.35em;
    letter-spacing: 0.2em;
    color: var(--color-ink-muted);
    margin-top: var(--space-3);
  }
  .about-body {
    font-family: var(--font-mincho);
    font-size: var(--fs-reading);
    line-height: var(--lh-reading);
    letter-spacing: var(--ls-reading);
    max-width: var(--max-reading);
  }
  .about-log h2,
  .about-credits h2 {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    color: var(--color-ink-muted);
    text-transform: uppercase;
  }
  .about-log h2 .jp-sub {
    font-family: var(--font-mincho);
    font-size: 0.9em;
    letter-spacing: 0.2em;
    color: var(--color-ink-muted);
    text-transform: none;
    margin-left: 0.5em;
  }

  /* --- CRONIKA digest (最新 3 件) --- */
  .log-digest {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
  }
  .log-digest li {
    border-top: 1px solid var(--color-rule);
  }
  .log-digest li:last-child {
    border-bottom: 1px solid var(--color-rule);
  }
  .log-link {
    display: grid;
    gap: var(--space-2);
    padding: var(--space-4) 0;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .log-link:hover,
  .log-link:focus-visible {
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-acid) 8%);
  }
  .log-meta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6em;
    flex-wrap: wrap;
    font-size: var(--fs-meta);
    letter-spacing: 0.14em;
  }
  .log-meta .acid {
    color: var(--color-acid);
  }
  .log-kind {
    display: inline-flex;
    gap: 0.4em;
    padding: 0.1em 0.5em;
    border: 1px solid var(--color-rule-strong);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
  }
  .kind-jp {
    font-family: var(--font-mincho);
    letter-spacing: 0.2em;
    color: var(--color-ink-muted);
  }
  .kind-add { border-color: var(--color-acid); }
  .kind-release { border-color: color-mix(in srgb, var(--color-acid) 55%, black); }
  .kind-fix { border-color: #c0331a; }
  .kind-note { border-color: var(--color-rule-strong); }

  .log-title {
    font-family: var(--font-mincho);
    font-size: 1.125rem;
    letter-spacing: 0.03em;
    color: var(--color-ink);
  }
  .log-more {
    padding-top: var(--space-3);
    font-size: var(--fs-meta);
    letter-spacing: 0.14em;
  }

  /* --- Credits --- */
  .about-credits dl {
    display: grid;
    gap: var(--space-3);
  }
  .about-credits dl > div {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: var(--space-4);
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-3);
  }
  .about-credits dt {
    color: var(--color-ink-muted);
    font-family: var(--font-mono);
    letter-spacing: var(--ls-meta);
  }
  .about-credits dd {
    color: var(--color-ink);
  }

  .codex-jump {
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }
  .codex-jump:hover,
  .codex-jump:focus-visible {
    border-bottom-color: var(--color-acid);
    color: var(--color-acid);
  }
  @media (max-width: 40rem) {
    .about-credits dl > div {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
