---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { buildDefinedTermNode, buildBreadcrumbNode } from '~/lib/jsonld';

export async function getStaticPaths() {
  const all = await getCollection('codex');
  return all.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const heroAspect = entry.data.heroAspect ?? '16:9';
const heroClass = `codex-hero hero-${heroAspect.replace(/[:.]/g, '-')}`;

// Load related lexicon and other codex entries
const relatedLex = await Promise.all(
  (entry.data.leksikoRefs ?? []).map((slug) => getEntry('lexicon', slug).catch(() => null)),
).then((arr) => arr.filter(Boolean));
const relatedCodex = await Promise.all(
  (entry.data.seeAlso ?? []).map((slug) => getEntry('codex', slug).catch(() => null)),
).then((arr) => arr.filter(Boolean));

// Novel chapters that mention this codex entry via mondoRefs (future-proofed for novel too)
// For now we don't have mondoRefs on novel, but we collect characters' mondoRefs.
const characters = await getCollection('characters');
const relatedChars = characters.filter((c) => (c.data.mondoRefs ?? []).includes(entry.slug));

// --- JSON-LD: DefinedTerm + Breadcrumb ----------------------------------
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.pathname;
const mondoIndexUrl = Astro.site
  ? new URL(`${base}/mondo/`, Astro.site).toString()
  : `${base}/mondo/`;
const siteUrl = Astro.site
  ? new URL(`${base}/`, Astro.site).toString()
  : `${base}/`;

const jsonLdNodes = [
  buildDefinedTermNode({
    url: canonicalUrl,
    name: entry.data.title,
    alternateName: entry.data.label,
    description: entry.data.summary,
    termCode: entry.data.codexId,
    inSetName: 'MONDO-DI NOTA',
    inSetUrl: mondoIndexUrl,
  }),
  buildBreadcrumbNode([
    { name: 'juicetopia', url: siteUrl },
    { name: '世界注', url: mondoIndexUrl },
    { name: entry.data.title, url: canonicalUrl },
  ]),
];
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  mode="bone"
  ogImage={entry.data.heroImage}
  ogImageAlt={entry.data.heroAlt ?? entry.data.title}
  jsonLdNodes={jsonLdNodes}
>
  <article class="codex-entry page-column" data-reveal>
    <header class="head">
      <p class="mono">
        <span class="acid">{entry.data.codexId}</span>
        <span class="sep">·</span>
        <span>MONDO-DI NOTA</span>
        {entry.data.cluster && (
          <>
            <span class="sep">·</span>
            <span>{entry.data.cluster}</span>
          </>
        )}
      </p>
      <h1 class="title">
        <span class="jp">{entry.data.title}</span>
        {entry.data.reading && <span class="reading mono">{entry.data.reading}</span>}
      </h1>
      <p class="label mono acid">{entry.data.label}</p>
      <p class="summary">{entry.data.summary}</p>
    </header>

    {entry.data.heroImage && (
      <figure class={heroClass} data-reveal>
        <div class="hero-frame">
          <Image
            src={entry.data.heroImage}
            alt={entry.data.heroAlt ?? entry.data.title}
            widths={[640, 960, 1280]}
            sizes="(min-width: 48rem) 40rem, 90vw"
          />
        </div>
        {entry.data.heroCaption && <figcaption class="mono">{entry.data.heroCaption}</figcaption>}
      </figure>
    )}

    <div class="rule"></div>

    <div class="body">
      <Content />
    </div>

    {(relatedLex.length > 0 || relatedCodex.length > 0 || relatedChars.length > 0) && (
      <>
        <div class="rule"></div>
        <aside class="refs flow-8" data-reveal>
          <h2 class="refs-head mono">REFS</h2>

          {relatedLex.length > 0 && (
            <section class="ref-block">
              <h3 class="ref-title mono meta-dim">LEKSIKO</h3>
              <ul class="ref-list">
                {relatedLex.map((l: any) => (
                  <li>
                    <a class="ref-link" href={`${base}/lexicon/#${l.slug}`}>
                      <span class="mono acid">{l.data.word}</span>
                      <span class="jp">{l.data.gloss}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {relatedCodex.length > 0 && (
            <section class="ref-block">
              <h3 class="ref-title mono meta-dim">MONDO · 参照</h3>
              <ul class="ref-list">
                {relatedCodex.map((c: any) => (
                  <li>
                    <a class="ref-link" href={`${base}/mondo/${c.slug}/`}>
                      <span class="mono acid">{c.data.codexId}</span>
                      <span class="jp">{c.data.title}</span>
                      <span class="ref-label mono meta-dim">{c.data.label}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {relatedChars.length > 0 && (
            <section class="ref-block">
              <h3 class="ref-title mono meta-dim">NOMA · 人物</h3>
              <ul class="ref-list">
                {relatedChars.map((c) => (
                  <li>
                    <a class="ref-link" href={`${base}/characters/${c.slug}/`}>
                      <span class="mono acid">{c.data.charId}</span>
                      <span class="jp">{c.data.name}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      </>
    )}

    <div class="rule"></div>

    <nav class="entry-nav mono" data-reveal>
      <a href={`${base}/mondo/`}>← INDEX · 世界注</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .codex-entry {
    max-width: var(--max-reading);
    margin-inline: auto;
    display: grid;
    gap: var(--space-8);
  }
  .head {
    display: grid;
    gap: var(--space-3);
  }
  .head .sep {
    color: var(--color-acid-ink);
    margin-inline: 0.4em;
  }
  .title {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: var(--ls-display);
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .title .jp {
    font-family: var(--font-mincho);
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .title .reading {
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    color: var(--color-ink-muted);
  }
  .label {
    font-size: var(--fs-meta);
    letter-spacing: 0.18em;
  }
  .summary {
    font-family: var(--font-mincho);
    font-size: var(--fs-reading);
    color: var(--color-ink-muted);
    line-height: var(--lh-reading);
    padding-inline-start: var(--space-4);
    border-inline-start: 2px solid var(--color-acid);
  }
  .body {
    font-family: var(--font-mincho);
    font-size: var(--fs-reading);
    line-height: var(--lh-reading);
    letter-spacing: var(--ls-reading);
  }
  .body :global(p) {
    margin-block: 1.4em;
  }
  .body :global(p:first-child) {
    margin-top: 0;
  }
  /* Shared hero figure styling — parallels ReadingLayout */
  .codex-hero {
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }
  .codex-hero .hero-frame {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-rule);
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-ink) 8%);
  }
  .codex-hero.hero-16-9 .hero-frame { aspect-ratio: 16 / 9; }
  .codex-hero.hero-4-3 .hero-frame { aspect-ratio: 4 / 3; }
  .codex-hero.hero-3-2 .hero-frame { aspect-ratio: 3 / 2; }
  .codex-hero.hero-1-1 .hero-frame { aspect-ratio: 1 / 1; }
  .codex-hero.hero-1-91-1 .hero-frame { aspect-ratio: 1.91 / 1; }
  .codex-hero .hero-frame :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .codex-hero figcaption {
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
    color: var(--color-ink-muted);
    padding-inline-start: 1em;
    border-inline-start: 1px solid var(--color-acid-dim);
  }
  .refs-head {
    font-size: var(--fs-meta);
    letter-spacing: 0.18em;
    color: var(--color-ink-muted);
  }
  .ref-block + .ref-block {
    margin-top: var(--space-4);
  }
  .ref-title {
    font-size: var(--fs-meta);
    letter-spacing: 0.14em;
    margin-bottom: var(--space-2);
  }
  .ref-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-2);
  }
  .ref-link {
    display: inline-flex;
    gap: var(--space-3);
    align-items: baseline;
    padding: var(--space-2) 0;
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-fast) var(--ease-out);
  }
  .ref-link:hover {
    border-bottom-color: var(--color-acid);
  }
  .ref-link .jp {
    font-family: var(--font-mincho);
  }
  .ref-label {
    font-size: var(--fs-meta);
    letter-spacing: 0.12em;
  }
  .entry-nav a {
    font-size: var(--fs-meta);
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
  }
  .entry-nav a:hover {
    color: var(--color-acid-ink);
  }
</style>
