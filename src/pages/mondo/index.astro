---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('codex');
const entries = all.sort((a, b) => a.data.order - b.data.order);
const pad = (n: number) => String(n).padStart(2, '0');

// Group by cluster (器 / 詩 / 手続き / 物質 / 制度 / 家系 / 様態 / 土地).
// NOTE: rendered element uses class "mondo-block" to avoid collision with the
// global .cluster flex utility in styles/utilities.css.
type Entry = (typeof entries)[number];
const groups = new Map<string, Entry[]>();
for (const e of entries) {
  const k = e.data.cluster ?? '';
  if (!groups.has(k)) groups.set(k, []);
  groups.get(k)!.push(e);
}
const clusterOrder = ['器', '詩', '物質', '手続き', '制度', '家系', '土地', '様態', ''];
const clusterLabelMap: Record<string, { label: string; sub: string }> = {
  '器': { label: 'BOLLA', sub: '器' },
  '詩': { label: 'POEMA', sub: '詩' },
  '物質': { label: 'MATERIA', sub: '物質' },
  '手続き': { label: 'FORNA', sub: '手続き' },
  '制度': { label: 'NORMA', sub: '制度' },
  '家系': { label: 'LINIA', sub: '家系' },
  '土地': { label: 'TERA', sub: '土地' },
  '様態': { label: 'MODA', sub: '様態' },
  '': { label: 'MANKA', sub: '未分類' },
};
const sections = clusterOrder
  .filter((k) => groups.has(k))
  .map((k) => ({
    key: k,
    meta: clusterLabelMap[k] ?? { label: k.toUpperCase(), sub: k },
    items: groups.get(k)!,
  }));
---

<BaseLayout title="MONDO-DI NOTA" description="juicetopia — 世界注 / codex." mode="bone">
  <section class="mondo page-column flow-16">
    <header class="flow" data-reveal>
      <h1 class="section-title">
        MONDO-DI NOTA<br />
        <span class="jp">世界注</span>
      </h1>
      <p class="mono">KODEKSO · {pad(entries.length)} FAKTA · {pad(sections.length)} BANDA</p>
    </header>

    <div class="rule"></div>

    <p class="lede" data-reveal>
      通読は想定していない。読みたいところから、あるいは他の文書から参照されたところから入ればよい。
      各項目は他の項目へ、ときに本文・人物・画像へと糸を伸ばす。糸は途中で切れてもよい。
    </p>

    <div class="rule"></div>

    {
      sections.map((sec) => (
        <article class="mondo-block flow-8" data-reveal>
          <header class="sec-head">
            <h2 class="sec-title">
              {sec.meta.label}
              <span class="sec-sub mono">{sec.meta.sub}</span>
            </h2>
            <span class="sec-count mono meta-dim">{pad(sec.items.length)} FAKTA</span>
          </header>
          <ul class="entry-list" data-reveal-stagger="25">
            {sec.items.map((c) => {
              const href = `${base}/mondo/${c.slug}/`;
              return (
                <li class="entry" data-reveal>
                  <a class="entry-link" href={href}>
                    <span class="entry-id mono">{c.data.codexId}</span>
                    <div class="entry-body">
                      <div class="entry-title-row">
                        <span class="entry-jp">{c.data.title}</span>
                        <span class="entry-label mono">{c.data.label}</span>
                      </div>
                      <p class="entry-summary">{c.data.summary}</p>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        </article>
      ))
    }

    <div class="rule"></div>

    <nav class="foot-nav" data-reveal>
      <a class="foot-link" href={`${base}/lexicon/`}>
        <span class="mono meta-dim">→ NEXT ·</span> <span class="foot-l">LEKSIKO</span>{' '}
        <span class="jp">辞書</span>
      </a>
    </nav>
  </section>
</BaseLayout>

<style>
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 0.95;
  }
  .section-title .jp {
    display: block;
    font-family: var(--font-mincho);
    font-size: 0.32em;
    letter-spacing: 0.25em;
    color: var(--color-ink-muted);
    margin-top: var(--space-3);
  }
  .lede {
    max-width: var(--max-reading);
    font-family: var(--font-mincho);
    font-size: var(--fs-reading);
    line-height: var(--lh-reading);
    color: var(--color-ink-muted);
  }
  .mondo-block + .mondo-block {
    margin-top: var(--space-10);
  }
  /* Unified with /novel/ section heads */
  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-rule);
  }
  .sec-title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    font-weight: 400;
    letter-spacing: 0.3em;
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-acid-dim);
  }
  .sec-sub {
    font-family: var(--font-mincho);
    font-size: 0.72em;
    letter-spacing: 0.2em;
    color: var(--color-ink-muted);
  }
  .sec-count {
    font-size: var(--fs-mono-sm);
    letter-spacing: 0.12em;
  }
  .entry-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .entry {
    border-bottom: 1px solid var(--color-rule);
  }
  .entry-link {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    align-items: baseline;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .entry-link:hover,
  .entry-link:focus-visible {
    background: color-mix(in srgb, var(--color-bg) 92%, var(--color-acid) 8%);
  }
  .entry-id {
    color: var(--color-acid);
    font-size: var(--fs-meta);
    letter-spacing: var(--ls-meta);
  }
  .entry-body {
    display: grid;
    gap: var(--space-2);
  }
  .entry-title-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .entry-jp {
    font-family: var(--font-mincho);
    font-size: 1.25rem;
    letter-spacing: 0.04em;
    color: var(--color-ink);
  }
  .entry-label {
    font-size: var(--fs-meta);
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
  }
  .entry-summary {
    font-family: var(--font-mincho);
    font-size: 0.95rem;
    color: var(--color-ink-muted);
    line-height: 1.7;
  }
  .foot-nav {
    padding-top: var(--space-4);
  }
  .foot-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5em;
    font-family: var(--font-mono);
    letter-spacing: 0.12em;
  }
  .foot-l {
    color: var(--color-acid);
  }
  .foot-link .jp {
    font-family: var(--font-mincho);
    color: var(--color-ink-muted);
    letter-spacing: 0.2em;
  }
</style>
