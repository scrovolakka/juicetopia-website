---
import BaseLayout from '~/layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="ERR 404" description="pana-na vida-ne." showRouteIndex={false}>
  <div class="nf page-column">
    <p class="mono">[ERR 404] · VOLA SENA-TAK</p>
    <h1 class="nf-title">SONO MANKA</h1>
    <p class="nf-jp">このページはアーカイブに存在しません。</p>
    <a class="acid-link mono" href={`${base}/`}>[00] MOKURO-NA MODA →</a>
  </div>
</BaseLayout>

<style>
  .nf {
    display: grid;
    gap: var(--space-6);
    justify-items: start;
    padding-block: var(--space-16);
  }
  .nf-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 12vw, 8rem);
    letter-spacing: -0.03em;
    line-height: 0.9;
    position: relative;
    animation: glitch 4s infinite;
  }
  @keyframes glitch {
    0%, 92%, 100% { transform: none; clip-path: none; }
    93% { transform: translate(-2px, 1px); clip-path: inset(20% 0 60% 0); }
    94% { transform: translate(2px, -1px); clip-path: inset(50% 0 20% 0); }
    95% { transform: translate(-1px, 0); clip-path: none; }
    96% { transform: translate(1px, 1px); clip-path: inset(30% 0 40% 0); }
    97% { transform: none; clip-path: none; }
  }
  .nf-jp {
    font-family: var(--font-mincho);
    font-size: var(--fs-reading);
    line-height: var(--lh-reading);
    color: var(--color-ink);
    letter-spacing: var(--ls-reading);
  }
</style>
